e-app-id-config.png","type":"image"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Click Create Certificate under the Production SSL Certificate "},{"type":"image","identifier":"apns-certificate-modal.png"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Production SSL Certificate","type":"text"}]},{"type":"text","text":" are suitable for App Store and TestFlight builds. Use a "},{"inlineContent":[{"type":"text","text":"Development SSL Certificate"}],"type":"strong"},{"type":"text","text":" to for development builds."}]}],"type":"aside","style":"note"}]}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Follow the instructions from the SSL certificate assistant."}],"type":"paragraph"}]}],"type":"orderedList"},{"content":[{"inlineContent":[{"text":"You must update your provisioning profile for the app after you create your SSL certificates. A simple “Refresh” in the organizer will accomplish this.","type":"text"}],"type":"paragraph"}],"name":"Note","style":"note","type":"aside"},{"anchor":"Step-2-Export-Certificate","type":"heading","level":4,"text":"Step 2: Export Certificate"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Download the production push certificate that you just created and open it with the Keychain Access application."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"In Keychain Access, click on My Certificates and locate your push certificate.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Export it as a "},{"code":".p12","type":"codeVoice"},{"type":"text","text":" file and use a temporary, unsecure password (you will need this password when uploading your certificate to Braze)."}]}]},{"content":[{"inlineContent":[{"text":"Navigate to the ","type":"text"},{"overridingTitle":"Settings","overridingTi