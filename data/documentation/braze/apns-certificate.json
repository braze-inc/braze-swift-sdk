{"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"BrazeKit"}],"title":"Apple Push Certificate"},"kind":"article","hierarchy":{"paths":[["doc:\/\/Braze\/documentation\/BrazeKit"]]},"identifier":{"url":"doc:\/\/Braze\/documentation\/Braze\/apns-certificate","interfaceLanguage":"swift"},"abstract":[{"text":"Create an Apple Push file or certificate.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"text":"Before you can send a push notification using Braze, you must provide your Push notification file or certificate from Apple. You may present either a ","type":"text"},{"code":".p8","type":"codeVoice"},{"text":" file (recommended) or a ","type":"text"},{"code":".p12","type":"codeVoice"},{"text":" certificate.","type":"text"}],"type":"paragraph"},{"anchor":"p8-File-recommended","text":".p8 File (recommended)","type":"heading","level":3},{"inlineContent":[{"text":"As described on this ","type":"text"},{"identifier":"https:\/\/help.apple.com\/developer-account\/#\/devcdfbb56a3","type":"reference","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In your developer account, go to "},{"identifier":"https:\/\/developer.apple.com\/account\/ios\/certificate","isActive":true,"type":"reference"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Under Keys, select All and click the Add button (+) in the upper-right corner."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Under Key Description, enter a unique name for the signing key."}]}]},{"content":[{"inlineContent":[{"text":"Under Key Services, select the APNs checkbox, then click Continue. Click ","type":"text"},{"inlineContent":[{"text":"Confirm","type":"text"}],"type":"emphasis"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Note the Key ID. Click ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Download"}]},{"text":" to generate and download the key now.","type":"text"}]}]}],"type":"orderedList"},{"style":"note","name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When you download the key, it is saved as a text file with a .p8 file extension. Save the file in a secure place because the key is "},{"type":"strong","inlineContent":[{"text":"not saved in your developer account and you won’t be able to download it again","type":"text"}]},{"type":"text","text":"."}]}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Navigate to the "},{"type":"reference","identifier":"https:\/\/dashboard-01.braze.com\/app_settings\/app_settings","isActive":true},{"type":"text","text":" page in the dashboard and upload the .p8 file."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"When prompted, also enter your app’s "},{"identifier":"https:\/\/developer.apple.com\/account\/ios\/identifier\/bundle\/","isActive":true,"type":"reference"},{"type":"text","text":", the "},{"identifier":"https:\/\/developer.apple.com\/account\/ios\/authkey","isActive":true,"type":"reference"},{"type":"text","text":" that you noted when generating the key, and your "},{"identifier":"https:\/\/developer.apple.com\/account\/#\/membership","isActive":true,"type":"reference"},{"type":"text","text":". Click "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Save"}]},{"type":"text","text":"."}],"type":"paragraph"}]}],"type":"orderedList"},{"anchor":"p12-Certificate-legacy","text":".p12 Certificate (legacy)","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Alternatively, you may utilize Apple’s older authentication scheme ("},{"type":"codeVoice","code":".p12"},{"type":"text","text":" SSL certificates). Unlike the "},{"type":"codeVoice","code":".p8"},{"type":"text","text":" solution described above, these certificates automatically expire every year and will require you to regenerate and re-upload them. Braze will send you email reminders as the certificate approaches expiration to help your notifications continue uninterrupted, but because this is a manual process we recommend utilizing the above-described "},{"type":"codeVoice","code":".p8"},{"type":"text","text":" authentication scheme instead. However, if you still wish to, you may configure and upload "},{"type":"codeVoice","code":".p12"},{"type":"text","text":" certificates as described here:"}],"type":"paragraph"},{"anchor":"Step-1-Generate-Certificate-Signing-Request","text":"Step 1: Generate Certificate Signing Request","type":"heading","level":4},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Navigate to the "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/ios\/manage\/overview\/index.action","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select "},{"type":"emphasis","inlineContent":[{"text":"Identifiers","type":"text"}]},{"type":"text","text":" in the left sidebar and filter "},{"type":"emphasis","inlineContent":[{"text":"App Ids","type":"text"}]},{"type":"text","text":" using the button on the right of the page "},{"type":"image","identifier":"apns-certificate-identifiers-app-ids.png"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Select your application."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enable push notifications by checking the checkbox then click ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Edit"}]},{"text":" ","type":"text"},{"identifier":"apns-certificate-app-id-config.png","type":"image"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Click Create Certificate under the Production SSL Certificate "},{"type":"image","identifier":"apns-certificate-modal.png"}]},{"type":"unorderedList","items":[{"content":[{"style":"note","content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Production SSL Certificate"}],"type":"strong"},{"text":" are suitable for App Store and TestFlight builds. Use a ","type":"text"},{"inlineContent":[{"type":"text","text":"Development SSL Certificate"}],"type":"strong"},{"text":" for development builds.","type":"text"}]}],"type":"aside","name":"Note"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Follow the instructions from the SSL certificate assistant."}]}]}],"type":"orderedList"},{"style":"note","name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You must update your provisioning profile for the app after you create your SSL certificates. A simple “Refresh” in the organizer will accomplish this."}]}]},{"anchor":"Step-2-Export-Certificate","text":"Step 2: Export Certificate","type":"heading","level":4},{"items":[{"content":[{"inlineContent":[{"text":"Download the production push certificate that you just created and open it with the Keychain Access application.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"In Keychain Access, click on My Certificates and locate your push certificate.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Export it as a ","type":"text"},{"code":".p12","type":"codeVoice"},{"text":" file and use a temporary, unsecure password (you will need this password when uploading your certificate to Braze).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Navigate to the "},{"identifier":"https:\/\/dashboard-01.braze.com\/app_settings\/app_settings","overridingTitleInlineContent":[{"text":"Settings","type":"text"}],"overridingTitle":"Settings","type":"reference","isActive":true},{"type":"text","text":" page in the dashboard and upload your production certificate. "},{"identifier":"apns-certificate-upload.png","type":"image"}]}]}],"type":"orderedList"},{"style":"note","name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can upload either your development or production push certificates to the dashboard for your distribution provisioning profile apps, but you can only have one active at a time. As such, if you wish to do repeated testing of push notifications once your app goes live in the App Store, we recommend setting up a separate App Group or App for the development version of your app."}]}]}]}],"seeAlsoSections":[{"identifiers":["doc:\/\/Braze\/tutorials\/Braze\/b1-standard-push-notifications"],"anchor":"Related-Documentation","title":"Related Documentation"},{"generated":true,"identifiers":["doc:\/\/Braze\/tutorials\/Braze\/b1-standard-push-notifications","doc:\/\/Braze\/tutorials\/Braze\/b2-rich-push-notifications","doc:\/\/Braze\/tutorials\/Braze\/b3-push-stories","doc:\/\/Braze\/tutorials\/Braze\/b4-live-activities"],"anchor":"Push-Notifications","title":"Push Notifications"}],"references":{"doc://Braze/documentation/BrazeKit":{"abstract":[{"type":"text","text":"The main Braze framework providing user sessions, attributes and events logging, push notification support."}],"identifier":"doc:\/\/Braze\/documentation\/BrazeKit","type":"topic","url":"\/documentation\/brazekit","kind":"symbol","title":"BrazeKit","role":"collection"},"doc://Braze/tutorials/Braze/b4-live-activities":{"kind":"project","identifier":"doc:\/\/Braze\/tutorials\/Braze\/b4-live-activities","abstract":[{"type":"text","text":"Learn how to remotely track and manage your iOS "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/activitykit\/updating-and-ending-your-live-activity-with-activitykit-push-notifications"},{"type":"text","