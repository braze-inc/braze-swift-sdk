{"abstract":[{"type":"text","text":"Create an Apple Push file or certificate."}],"hierarchy":{"paths":[["doc:\/\/Braze\/documentation\/BrazeKit"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Braze\/documentation\/Braze\/apns-certificate"},"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"inlineContent":[{"text":"Before you can send a push notification using Braze, you must provide your Push notification file or certificate from Apple. You may present either a ","type":"text"},{"code":".p8","type":"codeVoice"},{"text":" file (recommended) or a ","type":"text"},{"code":".p12","type":"codeVoice"},{"text":" certificate.","type":"text"}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"p8-File-recommended","text":".p8 File (recommended)"},{"inlineContent":[{"text":"As described on this ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/help.apple.com\/developer-account\/#\/devcdfbb56a3"},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"In your developer account, go to ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/account\/ios\/certificate","isActive":true,"type":"reference"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Under Keys, select All and click the Add button (+) in the upper-right corner."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Under Key Description, enter a unique name for the signing key."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Under Key Services, select the APNs checkbox, then click Continue. Click "},{"inlineContent":[{"text":"Confirm","type":"text"}],"type":"emphasis"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Note the Key ID. Click "},{"inlineContent":[{"type":"text","text":"Download"}],"type":"emphasis"},{"type":"text","text":" to generate and download the key now."}],"type":"paragraph"}]}],"type":"orderedList"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When you download the key, it is saved as a text file with a .p8 file extension. Save the file in a secure place because the key is "},{"type":"strong","inlineContent":[{"type":"text","text":"not saved in your developer account and you won’t be able to download it again"}]},{"type":"text","text":"."}]}],"type":"aside","style":"note","name":"Note"},{"items":[{"content":[{"inlineContent":[{"text":"Navigate to the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/dashboard-01.braze.com\/app_settings\/app_settings"},{"text":" page in the dashboard and upload the .p8 file.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When prompted, also enter your app’s "},{"identifier":"https:\/\/developer.apple.com\/account\/ios\/identifier\/bundle\/","type":"reference","isActive":true},{"type":"text","text":", the "},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/account\/ios\/authkey"},{"type":"text","text":" that you noted when generating the key, and your "},{"identifier":"https:\/\/developer.apple.com\/account\/#\/membership","type":"reference","isActive":true},{"type":"text","text":". Click "},{"inlineContent":[{"type":"text","text":"Save"}],"type":"emphasis"},{"type":"text","text":"."}]}]}],"type":"orderedList"},{"level":3,"type":"heading","text":".p12 Certificate (legacy)","anchor":"p12-Certificate-legacy"},{"type":"paragraph","inlineContent":[{"text":"Alternatively, you may utilize Apple’s older authentication scheme (","type":"text"},{"type":"codeVoice","code":".p12"},{"type":"text","text":" SSL certificates). Unlike the "},{"code":".p8","type":"codeVoice"},{"type":"text","text":" solution described above, these certificates automatically expire every year and will require you to regenerate and re-upload them. Braze will send you email reminders as the certificate approaches expiration to help your notifications continue uninterrupted, but because this is a manual process we recommend utilizing the above-described "},{"type":"codeVoice","code":".p8"},{"type":"text","text":" authentication scheme instead. However, if you still wish to, you may configure and upload "},{"type":"codeVoice","code":".p12"},{"text":" certificates as described here:","type":"text"}]},{"type":"heading","level":4,"text":"Step 1: Generate Certificate Signing Request","anchor":"Step-1-Generate-Certificate-Signing-Request"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Navigate to the "},{"identifier":"https:\/\/developer.apple.com\/ios\/manage\/overview\/index.action","type":"reference","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select "},{"type":"emphasis","inlineContent":[{"text":"Identifiers","type":"text"}]},{"type":"text","text":" in the left sidebar and filter "},{"inlineContent":[{"type":"text","text":"App Ids"}],"type":"emphasis"},{"text":" using the button on the right of the page ","type":"text"},{"type":"image","identifier":"apns-certificate-identifiers-app-ids.png"}]}]},{"content":[{"inlineContent":[{"text":"Select your application.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Enable push notifications by checking the checkbox then click "},{"inlineContent":[{"text":"Edit","type":"text"}],"type":"emphasis"},{"text":" ","type":"text"},{"identifier":"apns-certificate-app-id-config.png","type":"image"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Click Create Certificate under the Production SSL Certificate ","type":"text"},{"identifier":"apns-certificate-modal.png","type":"image"}]},{"type":"unorderedList","items":[{"content":[{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Production SSL Certificate"}]},{"text":" are suitable for App Store and TestFlight builds. Use a ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Development SSL Certificate"}]},{"text":" to for development builds.","type":"text"}],"type":"paragraph"}]}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Follow the instructions from the SSL certificate assistant."}]}]}]},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"You must update your provisioning profile for the app after you create your SSL certificates. A simple “Refresh” in the organizer will accomplish this.","type":"text"}]}],"name":"Note"},{"type":"heading","level":4,"text":"Step 2: Export Certificate","anchor":"Step-2-Export-Certificate"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Download the production push certificate that you just created and open it with the Keychain Access application."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In Keychain Access, click on My Certificates and locate your push certificate."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Export it as a ","type":"text"},{"type":"codeVoice","code":".p12"},{"type":"text","text":" file and use a temporary, unsecure password (you will need this password when uploading your certificate to Braze)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Navigate to the ","type":"text"},{"overridingTitle":"Settings","isActive":true,"type":"reference","identifier":"https:\/\/dashboard-01.braze.com\/app_settings\/app_settings","overridingTitleInlineContent":[{"type":"text","text":"Settings"}]},{"type":"text","text":" page in the dashboard and upload your production certificate. "},{"type":"image","identifier":"apns-certificate-upload.png"}]}]}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"You can upload either your development or production push certificates to the dashboard for your distribution provisioning profile apps, but you can only have one active at a time. As such, if you wish to do repeated testing of push notifications once your app goes live in the App Store, we recommend setting up a separate App Group or App for the development version of your app.","type":"text"}]}],"style":"note","name":"Note"}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"kind":"article","metadata":{"role":"article","modules":[{"name":"BrazeKit"}],"roleHeading":"Article","title":"Apple Push Certificate"},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/Braze\/tutorials\/Braze\/b1-standard-push-notifications"],"anchor":"Related-Documentation"},{"anchor":"Push-Notifications","title":"Push Notifications","generated":true,"identifiers":["doc:\/\/Braze\/tutorials\/Braze\/b1-standard-push-notifications","doc:\/\/Braze\/tutorials\/Braze\/b2-rich-push-notifications","doc:\/\/Braze\/tutorials\/Braze\/b3-push-stories","doc:\/\/Braze\/tutorials\/Braze\/b4-live-activities"]}],"references":{"https://developer.apple.com/account/ios/identifier/bundle/":{"type":"link","titleInlineContent":[{"type":"text","text":"Bundle ID"}],"identifier":"https:\/\/developer.apple.com\/account\/ios\/identifier\/bundle\/","title":"Bundle ID","url":"https:\/\/developer.apple.com\/account\/ios\/identifier\/bundle\/"},"doc://Braze/tutorials/Braze/b1-standard-push-notifications":{"estimatedTime":"20min","title":"Standard Push Notifications","kind":"project","type":"topic","role":"project","abstract":[{"type":"text","text":"Learn how to support receiving foreground and background push notifications."}],"identifier":"doc:\/\/Braze\/tutorials\/Braze\/b1-standard-push-notifications","url":"\/tutorials\/braze\/b1-standard-push-notifications"},"https://www.braze.com/do