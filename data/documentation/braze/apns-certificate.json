{"sections":[],"abstract":[{"type":"text","text":"Create an Apple Push file or certificate."}],"seeAlsoSections":[{"anchor":"Related-Documentation","identifiers":["doc:\/\/Braze\/tutorials\/Braze\/b1-standard-push-notifications"],"title":"Related Documentation"},{"anchor":"Push-Notifications","generated":true,"identifiers":["doc:\/\/Braze\/tutorials\/Braze\/b1-standard-push-notifications","doc:\/\/Braze\/tutorials\/Braze\/b2-rich-push-notifications","doc:\/\/Braze\/tutorials\/Braze\/b3-push-stories","doc:\/\/Braze\/tutorials\/Braze\/b4-live-activities"],"title":"Push Notifications"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before you can send a push notification using Braze, you must provide your Push notification file or certificate from Apple. You may present either a "},{"type":"codeVoice","code":".p8"},{"type":"text","text":" file (recommended) or a "},{"type":"codeVoice","code":".p12"},{"type":"text","text":" certificate."}]},{"level":3,"type":"heading","text":".p8 File (recommended)","anchor":"p8-File-recommended"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As described on this "},{"isActive":true,"type":"reference","identifier":"https:\/\/help.apple.com\/developer-account\/#\/devcdfbb56a3"},{"type":"text","text":":"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"In your developer account, go to ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/account\/ios\/certificate"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Under Keys, select All and click the Add button (+) in the upper-right corner."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Under Key Description, enter a unique name for the signing key.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Under Key Services, select the APNs checkbox, then click Continue. Click "},{"inlineContent":[{"type":"text","text":"Confirm"}],"type":"emphasis"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Note the Key ID. Click "},{"type":"emphasis","inlineContent":[{"text":"Download","type":"text"}]},{"type":"text","text":" to generate and download the key now."}]}]}]},{"name":"Note","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When you download the key, it is saved as a text file with a .p8 file extension. Save the file in a secure place because the key is "},{"type":"strong","inlineContent":[{"type":"text","text":"not saved in your developer account and you won’t be able to download it again"}]},{"text":".","type":"text"}]}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Navigate to the "},{"type":"reference","identifier":"https:\/\/dashboard-01.braze.com\/app_settings\/app_settings","isActive":true},{"type":"text","text":" page in the dashboard and upload the .p8 file."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"When prompted, also enter your app’s "},{"identifier":"https:\/\/developer.apple.com\/account\/ios\/identifier\/bundle\/","isActive":true,"type":"reference"},{"text":", the ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/account\/ios\/authkey","type":"reference"},{"text":" that you noted when generating the key, and your ","type":"text"},{"type":"reference","identifier":"https:\/\/developer.apple.com\/account\/#\/membership","isActive":true},{"text":". Click ","type":"text"},{"inlineContent":[{"text":"Save","type":"text"}],"type":"emphasis"},{"type":"text","text":"."}],"type":"paragraph"}]}],"type":"orderedList"},{"anchor":"p12-Certificate-legacy","type":"heading","text":".p12 Certificate (legacy)","level":3},{"inlineCon