eContent":[{"text":"Under Key Description, enter a unique name for the signing key.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Under Key Services, select the APNs checkbox, then click Continue. Click "},{"inlineContent":[{"type":"text","text":"Confirm"}],"type":"emphasis"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Note the Key ID. Click ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Download"}]},{"text":" to generate and download the key now.","type":"text"}]}]}]},{"style":"note","name":"Note","type":"aside","content":[{"inlineContent":[{"text":"When you download the key, it is saved as a text file with a .p8 file extension. Save the file in a secure place because the key is ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"not saved in your developer account and you won’t be able to download it again"}]},{"text":".","type":"text"}],"type":"paragraph"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Navigate to the "},{"type":"reference","isActive":true,"identifier":"https:\/\/dashboard-01.braze.com\/app_settings\/app_settings"},{"type":"text","text":" page in the dashboard and upload the .p8 file."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"When prompted, also enter your app’s "},{"identifier":"https:\/\/developer.apple.com\/account\/ios\/identifier\/bundle\/","isActive":true,"type":"reference"},{"type":"text","text":", the "},{"identifier":"https:\/\/developer.apple.com\/account\/ios\/authkey","isActive":true,"type":"reference"},{"type":"text","text":" that you noted when generating the key, and your "},{"identifier":"https:\/\/developer.apple.com\/account\/#\/membership","isActive":true,"type":"reference"},{"type":"text","text":". Click "},{"inlineContent":[{"text":"Save","type":"text"}],"type":"emphasis"},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"text":".p12 Certificate (legacy)","type":"heading","anchor":"p12-Certificate-legacy","level":3},{"type":"paragraph","inlineContent":[{"text":"Alternatively, you may utilize Apple’s older authentication scheme (","type":"text"},{"type":"codeVoice","code":".p12"},{"text":" SSL certificates). Unlike the ","type":"text"},{"type":"codeVoice","code":".p8"},{"text":" solution described above, these certificates automatically expire every year and will require you to regenerate and re-upload them. Braze will send you email reminders as the certificate approaches expiration to help your notifications continue uninterrupted, but because this is a manual process we recommend utilizing the above-described ","type":"text"},{"type":"codeVoice","code":".p8"},{"text":" authentication scheme instead. However, if you still wish to, you may configure and upload ","type":"text"},{"type":"codeVoice","code":".p12"},{"text":" certificates as described here:","type":"text"}]},{"text":"Step 1: Generate Certificate Signing Request","type":"heading","anchor":"Step-1-Generate-Certificate-Signing-Request","level":4},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Navigate to the "},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/ios\/manage\/overview\/index.action"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Select ","type":"text"},{"inlineContent":[{"type":"text","text":"Identifiers"}],"type":"emphasis"},{"text":" in the left sidebar and filter ","type":"text"},{"inlineContent":[{"text":"App Ids","type":"text"}],"type":"emphasis"},{"text":" using the button on the right of the page ","type":"text"},{"identifier":"apns-certificate-identifiers-app-ids.png","type":"image"}]}]},{"content":[{"inlineContent":[{"text":"Select your application.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Enable push notifications by 