{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Braze\/documentation\/Braze\/apns-certificate"},"seeAlsoSections":[{"anchor":"Related-Documentation","identifiers":["doc:\/\/Braze\/tutorials\/Braze\/b1-standard-push-notifications"],"title":"Related Documentation"},{"generated":true,"anchor":"Push-Notifications","identifiers":["doc:\/\/Braze\/tutorials\/Braze\/b1-standard-push-notifications","doc:\/\/Braze\/tutorials\/Braze\/b2-rich-push-notifications","doc:\/\/Braze\/tutorials\/Braze\/b3-push-stories","doc:\/\/Braze\/tutorials\/Braze\/b4-live-activities"],"title":"Push Notifications"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/Braze\/documentation\/BrazeKit"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"Create an Apple Push file or certificate."}],"kind":"article","primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"Before you can send a push notification using Braze, you must provide your Push notification file or certificate from Apple. You may present either a ","type":"text"},{"type":"codeVoice","code":".p8"},{"text":" file (recommended) or a ","type":"text"},{"type":"codeVoice","code":".p12"},{"text":" certificate.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"p8-File-recommended","text":".p8 File (recommended)","type":"heading"},{"inlineContent":[{"type":"text","text":"As described on this "},{"type":"reference","isActive":true,"identifier":"https:\/\/help.apple.com\/developer-account\/#\/devcdfbb56a3"},{"type":"text","text":":"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In your developer account, go to "},{"identifier":"https:\/\/developer.apple.com\/account\/ios\/certificate","type":"reference","isActive":true},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Under Keys, select All and click the Add button (+) in the upper-right corner."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Under Key Description, enter a unique name for the signing key.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Under Key Services, select the APNs checkbox, then click Continue. Click "},{"type":"emphasis","inlineContent":[{"text":"Confirm","type":"text"}]},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"text":"Note the Key ID. Click ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Download"}]},{"text":" to generate and download the key now.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"style":"note","content":[{"inlineContent":[{"text":"When you download the key, it is saved as a text file with a .p8 file extension. Save the file in a secure place because the key is ","type":"text"},{"inlineContent":[{"text":"not saved in your developer account and you won’t be able to download it again","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"}],"name":"Note","type":"aside"},{"items":[{"content":[{"inlineContent":[{"text":"Navigate to the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/dashboard-01.braze.com\/app_settings\/app_settings"},{"text":" page in the dashboard and upload the .p8 file.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"When prompted, also enter your app’s ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/account\/ios\/identifier\/bundle\/","type":"reference","isActive":true},{"text":", the ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/account\/ios\/authkey","type":"reference","isActive":true},{"text":" that you noted when generating the key, and your ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/account\/#\/membership","type":"reference","isActive":true},{"text":". Click ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Save"}]},{"text":".","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"level":3,"anchor":"p12-Certificate-legacy","text":".p12 Certificate (legacy)","type":"heading"},{"inlineContent":[{"type":"text","text":"Alternatively, you may utilize Apple’s older authentication scheme ("},{"code":".p12","type":"codeVoice"},{"type":"text","text":" SSL certificates). Unlike the "},{"code":".p8","type":"codeVoice"},{"type":"text","text":" solution described above, these certificates automatically expire every year and will require you to regenerate and re-upload them. Braze will send you email reminders as the certificate approaches expiration to help your notifications continue uninterrupted, but because this is a manual process we recommend utilizing the above-described "},{"code":".p8","type":"codeVoice"},{"type":"text","text":" authentication scheme instead. However, if you still wish to, you may configure and upload "},{"code":".p12","type":"codeVoice"},{"type":"text","text":" certificates as described here:"}],"type":"paragraph"},{"level":4,"anchor":"Step-1-Generate-Certificate-Signing-Request","text":"Step 1: Generate Certificate Signing Request","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Navigate to the "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/ios\/manage\/overview\/index.action"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Select ","type":"text"},{"inlineContent":[{"type":"text","text":"Identifiers"}],"type":"emphasis"},{"text":" in the left sidebar and filter ","type":"text"},{"inlineContent":[{"type":"text","text":"App Ids"}],"type":"emphasis"},{"text":" using the button on the right of the page ","type":"text"},{"identifier":"apns-certificate-identifiers-app-ids.png","type":"image"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select your application."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enable push notifications by checking the checkbox then click "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Edit"}]},{"type":"text","text":" "},{"type":"image","identifier":"apns-certificate-app-id-config.png"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Click Create Certificate under the Production SSL Certificate "},{"type":"image","identifier":"apns-certificate-modal.png"}]},{"items":[{"content":[{"type":"aside","name":"Note","content":[{"inlineContent":[{"inlineContent":[{"text":"Production SSL Certificate","type":"text"}],"type":"strong"},{"text":" are suitable for App Store and TestFlight builds. Use a ","type":"text"},{"inlineContent":[{"text":"Development SSL Certificate","type":"text"}],"type":"strong"},{"text":" for development builds.","type":"text"}],"type":"paragraph"}],"style":"note"}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Follow the instructions from the SSL certificate assistant."}]}]}],"type":"orderedList"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"You must update your provisioning profile for the app after you create your SSL certificates. A simple “Refresh” in the organizer will accomplish this."}],"type":"paragraph"}],"name":"Note","type":"aside"},{"level":4,"anchor":"Step-2-Export-Certificate","text":"Step 2: Export Certificate","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Download the production push certificate that you just created and open it with the Keychain Access application.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In Keychain Access, click on My Certificates and locate your push certificate."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Export it as a ","type":"text"},{"type":"codeVoice","code":".p12"},{"text":" file and use a te