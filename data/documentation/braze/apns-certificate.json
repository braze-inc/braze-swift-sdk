":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Save"}]},{"text":".","type":"text"}]}]}]},{"type":"heading","level":3,"anchor":"p12-Certificate-legacy","text":".p12 Certificate (legacy)"},{"type":"paragraph","inlineContent":[{"text":"Alternatively, you may utilize Apple’s older authentication scheme (","type":"text"},{"type":"codeVoice","code":".p12"},{"text":" SSL certificates). Unlike the ","type":"text"},{"type":"codeVoice","code":".p8"},{"text":" solution described above, these certificates automatically expire every year and will require you to regenerate and re-upload them. Braze will send you email reminders as the certificate approaches expiration to help your notifications continue uninterrupted, but because this is a manual process we recommend utilizing the above-described ","type":"text"},{"type":"codeVoice","code":".p8"},{"text":" authentication scheme instead. However, if you still wish to, you may configure and upload ","type":"text"},{"type":"codeVoice","code":".p12"},{"text":" certificates as described here:","type":"text"}]},{"type":"heading","level":4,"anchor":"Step-1-Generate-Certificate-Signing-Request","text":"Step 1: Generate Certificate Signing Request"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Navigate to the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/ios\/manage\/overview\/index.action"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Select "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Identifiers"}]},{"type":"text","text":" in the left sidebar and filter "},{"type":"emphasis","inlineContent":[{"text":"App Ids","type":"text"}]},{"type":"text","text":" using the button on the right of the page "},{"type":"image","identifier":"apns-certificate-identifiers-app-ids.png"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Select your application.","type":"text"}],"type":"paragraph"}]},{"