{"metadata":{"modules":[{"name":"BrazeKit"}],"roleHeading":"Article","role":"article","title":"Content Cards UI Customization"},"abstract":[{"type":"text","text":"The "},{"code":"BrazeUI","type":"codeVoice"},{"type":"text","text":" module provides high quality native Content Cards UI components. These components are easily customizable to better fit the look and feel of your application."}],"seeAlsoSections":[{"title":"User Interface","identifiers":["doc:\/\/Braze\/tutorials\/Braze\/c1-inappmessageui","doc:\/\/Braze\/documentation\/Braze\/in-app-message-customization","doc:\/\/Braze\/tutorials\/Braze\/c2-contentcardsui","doc:\/\/Braze\/tutorials\/Braze\/c4-bannersui","doc:\/\/Braze\/tutorials\/Braze\/c3-gif-support","doc:\/\/Braze\/documentation\/Braze\/gif-support-integrations"],"generated":true,"anchor":"User-Interface"}],"identifier":{"url":"doc:\/\/Braze\/documentation\/Braze\/content-cards-customization","interfaceLanguage":"swift"},"kind":"article","hierarchy":{"paths":[["doc:\/\/Braze\/documentation\/BrazeKit"],["doc:\/\/Braze\/documentation\/BrazeKit","doc:\/\/Braze\/documentation\/BrazeKit\/Braze"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"primaryContentSections":[{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"image","identifier":"content-card-customization-attributes.png"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"All "},{"type":"codeVoice","code":"BrazeUI"},{"type":"text","text":" components are crafted with the following principles in mind:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Accessible"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Follow accessibility guidelines and are compatible with VoiceOver.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Support "},{"identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/uifont\/scaling_fonts_automatically","isActive":true,"type":"reference"},{"type":"text","text":"."}]}]}],"type":"unorderedList"}]},{"content":[{"inlineContent":[{"type":"text","text":"Themeable"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Light and dark mode compatible."}],"type":"paragraph"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Adaptive to multiple layouts"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Support multiple device sizes and orientations, including "},{"identifier":"https:\/\/support.apple.com\/en-us\/HT207582","type":"reference","isActive":true},{"type":"text","text":" UIs."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Support "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/uiview\/positioning_content_relative_to_the_safe_area"},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/uiview\/positioning_content_within_layout_margins"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Support ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/foundations\/right-to-left\/","type":"reference"},{"text":" layouts.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Support on-screen keyboard."}],"type":"paragraph"}]}]}]},{"content":[{"inlineContent":[{"text":"Customizable","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Padding, margin, spacing, font, image size and more."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Sensible defaults."}]}]}],"type":"unorderedList"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"For these reasons, we recommend trying to customize the "},{"type":"codeVoice","code":"BrazeUI"},{"type":"text","text":" components before creating your own custom components."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Nonetheless, we understand that there are cases where the look and feel of your application cannot be achieved via our customization APIs. In these cases, we support multiple ways you can integrate your own custom components with the Braze SDK (See the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Custom UI"}]},{"type":"text","text":" section)."}],"type":"paragraph"},{"anchor":"Content-Cards-Attributes","level":2,"text":"Content Cards Attributes","type":"heading"},{"inlineContent":[{"text":"Depending on the type of the content card, the ","type":"text"},{"type":"codeVoice","code":"BrazeUI"},{"text":" module defaults to one of the cells below for display. These cells can be customized all at once by modifying the content card view controller ","type":"text"},{"type":"codeVoice","code":"Attributes"},{"text":" struct.","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/braze-inc.github.io\/braze-swift-sdk\/documentation\/brazeui\/brazecontentcardui\/classiccell\/","isActive":true,"type":"reference"}]}]},{"content":[{"inlineContent":[{"identifier":"https:\/\/braze-inc.github.io\/braze-swift-sdk\/documentation\/brazeui\/brazecontentcardui\/classicimagecell\/","isActive":true,"type":"reference"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"https:\/\/braze-inc.github.io\/braze-swift-sdk\/documentation\/brazeui\/brazecontentcardui\/imageonlycell\/","isActive":true,"type":"reference"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/braze-inc.github.io\/braze-swift-sdk\/documentation\/brazeui\/brazecontentcardui\/captionedimagecell\/","isActive":true,"type":"reference"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/braze-inc.github.io\/braze-swift-sdk\/documentation\/brazeui\/brazecontentcardui\/controlcell\/"}]}]}],"type":"unorderedList"},{"name":"Important","style":"important","content":[{"inlineContent":[{"type":"text","text":"Content card properties such as title, description, image, etc. are directly available on the "},{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/ContentCard","isActive":true},{"type":"text","text":" data type. Configuring content cards campaign on the Braze dashboard is the preferred way to customize these properties."}],"type":"paragraph"}],"type":"aside"},{"anchor":"Customizing-via-Attributes","level":3,"text":"Customizing via Attributes","type":"heading"},{"inlineContent":[{"type":"text","text":"We offer two ways to customize the "},{"type":"codeVoice","code":"BrazeUI"},{"type":"text","text":" content card view controller and associated cells via the "},{"type":"codeVoice","code":"Attributes"},{"type":"text","text":" struct:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Modifying the "},{"code":"Attributes.defaults","type":"codeVoice"},{"type":"text","text":" static variable."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Passing an "},{"type":"codeVoice","code":"Attributes"},{"type":"text","text":" struct to the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeUI\/BrazeContentCardUI\/ViewController"},{"type":"text","text":" initializer."}]}]}],"type":"unorderedList"},{"anchor":"Modifying-the-Attributesdefaults-static-variable","level":4,"text":"Modifying the `Attributes.defaults` static variable","type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"Attributes.defaults"},{"type":"text","text":" static variable is a convenient way to modify the default attributes for all Content Cards view controller and associated cells."}],"type":"paragraph"},{"inlineContent":[{"text":"For example, to change the default image size and corner radius for all cells, you can write the following code:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["BrazeContentCardUI.ViewController.Attributes.defaults.cellAttributes.cornerRadius = 20","BrazeContentCardUI.ViewController.Attributes.defaults.cellAttributes.classicImageSize = CGSize(width: 65, height: 65)"],"type":"codeListing"},{"anchor":"Passing-an-Attributes-struct-to-the-view-controller-initializer","level":4,"text":"Passing an `Attributes` struct to the view controller initializer","type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"https:\/\/braze-inc.github.io\/braze-swift-sdk\/documentation\/brazeui\/brazecontentcardui\/viewcontroller\/init(braze:attributes:)","isActive":true},{"type":"text","text":" initializer can be used to pass a custom "},{"type":"codeVoice","code":"Attributes"},{"type":"text","text":" struct to the view controller."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, you can change the image size and corner radius for a specific instance of the view controller:"}],"type":"paragraph"},{"syntax":"swift","code":["var attributes = BrazeContentCardUI.ViewController.Attributes.defaults","attributes.cellAttributes.cornerRadius = 20","attributes.cellAttributes.classicImageSize = CGSize(width: 65, height: 65)","","let viewController = BrazeContentCardUI.ViewController(braze: AppDelegate.braze, attributes: attributes)"],"type":"codeListing"},{"anchor":"Dark-theme-customization","level":4,"text":"Dark theme customization","type":"heading"},{"inlineContent":[{"type":"text","text":"By default, Content Card views will automatically respond to Dark Mode changes on the device with a set of themed colors and layout changes."}],"type":"paragraph"},{"inlineContent":[{"text":"This behavior can be overridden by setting the ","type":"text"},{"code":"Attributes.enableDarkTheme","type":"codeVoice"},{"text":" property to ","type":"text"},{"code":"false","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Option 1: Directly modifying the `Attributes.defaults` static variable.","BrazeContentCardUI.ViewController.Attributes.defaults.enabledDarkTheme = false","","\/\/ Option 2: Passing a modified `Attributes` struct to the view controller initializer.","var attributes = BrazeContentCardUI.ViewController.Attributes.defaults","attributes.enableDarkTheme = false","let viewController = BrazeContentCardUI.ViewController(braze: AppDelegate.braze, attributes: attributes)"],"type":"codeListing"},{"anchor":"Customizing-via-subclassing","level":2,"text":"Customizing via subclassing","type":"heading"},{"inlineContent":[{"text":"For cases where the ","type":"text"},{"code":"Attributes","type":"codeVoice"},{"text":" struct is not enough, you can subclass one or multiple Content Card cells to customize them further.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To use your subclass instead of the default cell, you can modify the ","type":"text"},{"identifier":"https:\/\/braze-inc.github.io\/braze-swift-sdk\/documentation\/brazeui\/brazecontentcardui\/viewcontroller\/attributes-swift.struct\/cells","isActive":true,"type":"reference"},{"text":" property of the ","type":"text"},{"code":"Attributes","type":"codeVoice"},{"text":" struct:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var attributes = BrazeContentCardUI.ViewController.Attributes.defaults","attributes.cells[BrazeContentCardUI.ClassicImageCell.identifier] = CustomClassicImageCell.self","","let viewController = BrazeContentCardUI.ViewController(braze: AppDelegate.braze, attributes: attributes)"],"type":"codeListing"},{"anchor":"Custom-UI","level":2,"text":"Custom UI","type":"heading"},{"inlineContent":[{"type":"text","text":"For cases where subclassing is not enough, you can implement your own Content Cards UI using the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/ContentCards-swift.class"},{"type":"text","text":" class. This does not require "},{"type":"codeVoice","code":"BrazeUI"},{"type":"text","text":" — all content cards data types and methods are available directly in "},{"type":"codeVoice","code":"BrazeKit"},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Subscribing-to-Updates","level":3,"text":"Subscribing to Updates","type":"heading"},{"inlineContent":[{"text":"You can use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/ContentCards-swift.class\/subscribeToUpdates(_:)"},{"text":" to drive your UI. The subscription delivers an initial snapshot of the cached cards immediately, then all subsequent updates as cards change on the server or as local analytics state (viewed, clicked, removed) mutates.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class CustomContentCardsViewController: UITableViewController {","","    let braze: Braze","    var subscription: Braze.Cancellable?","","    override func viewDidLoad() {","        super.viewDidLoad()","        subscription = braze.contentCards.subscribeToUpdates { [weak self] cards in","            self?.reloadCards(cards)","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"In Objective-C:"}],"type":"paragraph"},{"syntax":"objc","code":["@interface CustomContentCardsViewController ()","@property(strong, nonatomic) BRZCancellable *subscription;","@end","","@implementation CustomContentCardsViewController","","- (void)viewDidLoad {","    [super viewDidLoad];","    __weak typeof(self) weakSelf = self;","    self.subscription = [self.braze.contentCards","        subscribeToUpdates:^(NSArray<BRZContentCardRaw *> *cards) {","            [weakSelf reloadCards:cards];","        }];","}","","@end"],"type":"codeListing"},{"anchor":"Subscription-Lifecycle","level":3,"text":"Subscription Lifecycle","type":"heading"},{"inlineContent":[{"type":"text","text":"Cancelling the subscription re-applies any local analytics changes (viewed, clicked, removed) to the card store and notifies other active subscribers. This means subsequent presentations of any content cards UI — including "},{"type":"codeVoice","code":"BrazeContentCardUI.ViewController"},{"type":"text","text":" — will always reflect accurate state. These analytic methods do not automatically notify the subscribers outside of when the subscription is cancelled"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The subscription is cancelled automatically when the "},{"type":"codeVoice","code":"Braze.Cancellable"},{"type":"text","text":" ("},{"type":"codeVoice","code":"BRZCancellable"},{"type":"text","text":" in Objective-C) is deallocated, so setting it to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" (or letting the view controller deallocate) is sufficient. Cancelling explicitly gives you more precise control over when reconciliation occurs."}],"type":"paragraph"},{"anchor":"Logging-Analytics","level":3,"text":"Logging Analytics","type":"heading"},{"inlineContent":[{"text":"The custom UI must:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Log impressions by calling ","type":"text"},{"type":"codeVoice","code":"logImpression()"},{"text":" using ","type":"text"},{"type":"codeVoice","code":"card.context"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Log clicks by calling "},{"code":"logClick()","type":"codeVoice"},{"type":"text","text":" using "},{"code":"card.context","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Log dismissals by calling ","type":"text"},{"code":"logDismissed()","type":"codeVoice"},{"text":" using ","type":"text"},{"code":"card.context","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Process the click action by calling "},{"type":"codeVoice","code":"processClickAction(_:)"},{"type":"text","text":" using "},{"type":"codeVoice","code":"card.context"},{"type":"text","text":"."}],"type":"paragraph"}]}],"type":"unorderedList"},{"name":"Tip","style":"tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"See the "},{"type":"codeVoice","code":"ContentCards-Custom-UI"},{"type":"text","text":" scheme of the Examples project for a complete Swift and Objective-C implementation."}]}],"type":"aside"},{"anchor":"Customization-Recipes","level":2,"text":"Customization Recipes","type":"heading"},{"inlineContent":[{"type":"text","text":"This section presents multiple recipes for common customization use cases."}],"type":"paragraph"},{"anchor":"Tint-Color","level":4,"text":"Tint Color","type":"heading"},{"inlineContent":[{"text":"The cell unviewed indicator, pin image and domain label color automatically adopts your application’s ","type":"text"},{"code":"tintColor","type":"codeVoice"},{"text":". This color can be changed by setting the ","type":"text"},{"code":"tintColor","type":"codeVoice"},{"text":" property of the ","type":"text"},{"code":"BrazeContentCardUI.ViewController","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let viewController = BrazeContentCardUI.ViewController(braze: AppDelegate.braze)","viewController.view.tintColor = .systemGreen"],"type":"codeListing"},{"inlineContent":[{"identifier":"content-card-customization-tint.png","type":"image"}],"type":"paragraph"},{"anchor":"Hide-the-Unviewed-Indicator","level":4,"text":"Hide the Unviewed Indicator","type":"heading"},{"inlineContent":[{"text":"The unviewed indicator can be hidden by setting the ","type":"text"},{"type":"codeVoice","code":"unviewedIndicatorColor"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"UIColor.clear"},{"text":" on the Attributes struct:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var attributes = BrazeContentCardUI.ViewController.Attributes.defaults","attributes.cellAttributes.unviewedIndicatorColor = .clear","","let viewController = BrazeContentCardUI.ViewController(braze: AppDelegate.braze, attributes: attributes)"],"type":"codeListing"},{"anchor":"Filter-Content-Cards","level":4,"text":"Filter Content Cards","type":"heading"},{"inlineContent":[{"type":"text","text":"The cards presented in the view controller can be filtered by setting the "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" property on the Attributes struct."}],"type":"paragraph"},{"inlineContent":[{"text":"The example below displays only cards for which the key-value pair ","type":"text"},{"code":"home_feed: true","type":"codeVoice"},{"text":" is present in the ","type":"text"},{"code":"extras","type":"codeVoice"},{"text":" dictionary.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var attributes = BrazeContentCardUI.ViewController.Attributes.defaults","attributes.transform = { cards in","  cards.filter { $0.extras[\"home_feed\"] as? Bool == true }","}","","let viewController = BrazeContentCardUI.ViewController(braze: AppDelegate.braze, attributes: attributes)"],"type":"codeListing"},{"inlineContent":[{"type":"image","identifier":"content-card-customization-filtered.png"}],"type":"paragraph"},{"anchor":"Transform-Content-Cards","level":4,"text":"Transform Content Cards","type":"heading"},{"inlineContent":[{"text":"The cards presented can be transformed by setting the ","type":"text"},{"code":"transform","type":"codeVoice"},{"text":" property on the Attributes struct.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The example below modifies the "},{"type":"codeVoice","code":"title"},{"type":"text","text":" and "},{"type":"codeVoice","code":"description"},{"type":"text","text":" of compatible cards."}],"type":"paragraph"},{"syntax":"swift","code":["var attributes = BrazeContentCardUI.ViewController.Attributes.defaults","attributes.transform = { cards in","  cards.map { card in","    var card = card","    if let title = card.title {","      card.title = \"[modified] \\(title)\"","    }","    if let description = card.description {","      card.description = \"[modified] \\(description)\"","    }","    return card","  }","}","","let viewController = BrazeContentCardUI.ViewController(braze: AppDelegate.braze, attributes: attributes)"],"type":"codeListing"},{"inlineContent":[{"identifier":"content-card-customization-transformed.png","type":"image"}],"type":"paragraph"},{"anchor":"Empty-State","level":4,"text":"Empty State","type":"heading"},{"inlineContent":[{"type":"text","text":"The view controller empty state can be customized by setting the related attributes."}],"type":"paragraph"},{"syntax":"swift","code":["var attributes = BrazeContentCardUI.ViewController.Attributes.defaults","attributes.emptyStateMessage = \"This is a custom empty state message\"","attributes.emptyStateMessageFont = .preferredFont(forTextStyle: .title1)","attributes.emptyStateMessageColor = .secondaryLabel"],"type":"codeListing"},{"inlineContent":[{"identifier":"content-card-customization-empty.png","type":"image"}],"type":"paragraph"},{"anchor":"More-customization","level":4,"text":"More customization","type":"heading"},{"inlineContent":[{"type":"text","text":"More examples of customization can be found in the "},{"type":"codeVoice","code":"ContentCardUI-Customization"},{"type":"text","text":" and "},{"type":"codeVoice","code":"ContentCards-Custom-UI"},{"type":"text","text":" schemes of the Examples project."}],"type":"paragraph"}]}],"references":{"content-card-customization-tint.png":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/Braze\/content-card-customization-tint.png"},{"traits":["1x","dark"],"url":"\/images\/Braze\/content-card-customization-tint~dark.png"}],"alt":"Tint Color","identifier":"content-card-customization-tint.png"},"doc://Braze/documentation/BrazeKit/Braze/ContentCards-swift.class":{"abstract":[{"text":"The content cards module exposes the Braze SDK content cards related properties and methods.","type":"text"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"ContentCards"}],"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/ContentCards-swift.class","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"ContentCards"}],"title":"Braze.ContentCards","url":"\/documentation\/brazekit\/braze\/contentcards-swift.class"},"doc://Braze/documentation/Braze/in-app-message-customization":{"role":"article","title":"In-App Message UI Customization","url":"\/documentation\/braze\/in-app-message-customization","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"BrazeUI"},{"type":"text","text":" module provides high quality native In-App Message UI components. These components are easily customizable to better fit the look and feel of your application."}],"kind":"article","identifier":"doc:\/\/Braze\/documentation\/Braze\/in-app-message-customization","type":"topic"},"https://braze-inc.github.io/braze-swift-sdk/documentation/brazeui/brazecontentcardui/controlcell/":{"identifier":"https:\/\/braze-inc.github.io\/braze-swift-sdk\/documentation\/brazeui\/brazecontentcardui\/controlcell\/","titleInlineContent":[{"code":"Control","type":"codeVoice"}],"url":"https:\/\/braze-inc.github.io\/braze-swift-sdk\/documentation\/brazeui\/brazecontentcardui\/controlcell\/","type":"link","title":"Control"},"https://braze-inc.github.io/braze-swift-sdk/documentation/brazeui/brazecontentcardui/classicimagecell/":{"type":"link","url":"https:\/\/braze-inc.github.io\/braze-swift-sdk\/documentation\/brazeui\/brazecontentcardui\/classicimagecell\/","titleInlineContent":[{"code":"ClassicImageCell","type":"codeVoice"}],"identifier":"https:\/\/braze-inc.github.io\/braze-swift-sdk\/documentation\/brazeui\/brazecontentcardui\/classicimagecell\/","title":"ClassicImageCell"},"doc://Braze/documentation/BrazeUI/GIFViewProvider":{"type":"topic","kind":"symbol","title":"GIFViewProvider","role":"symbol","abstract":[{"text":"A type providing methods to create and update views supporting animated GIF images.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"GIFViewProvider"}],"url":"\/documentation\/brazeui\/gifviewprovider","identifier":"doc:\/\/Braze\/documentation\/BrazeUI\/GIFViewProvider","navigatorTitle":[{"kind":"identifier","text":"GIFViewProvider"}]},"https://developer.apple.com/documentation/uikit/uifont/scaling_fonts_automatically":{"identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/uifont\/scaling_fonts_automatically","titleInlineContent":[{"type":"text","text":"Dynamic Type"}],"url":"https:\/\/developer.apple.com\/documentation\/uikit\/uifont\/scaling_fonts_automatically","type":"link","title":"Dynamic Type"},"doc://Braze/documentation/Braze/gif-support-integrations":{"abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeUI\/GIFViewProvider"},{"type":"text","text":" implementations for common third party GIF images libraries."}],"role":"article","type":"topic","title":"GIF Support Integrations","kind":"article","url":"\/documentation\/braze\/gif-support-integrations","identifier":"doc:\/\/Braze\/documentation\/Braze\/gif-support-integrations"},"doc://Braze/documentation/BrazeKit/Braze/ContentCard":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ContentCard","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/brazekit\/braze\/contentcard","navigatorTitle":[{"text":"ContentCard","kind":"identifier"}],"ty