{"metadata":{"modules":[{"name":"BrazeKit"}],"role":"article","title":"Device ID Configuration","roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/Braze\/documentation\/BrazeKit"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"seeAlsoSections":[{"title":"Customize Behavior","anchor":"Customize-Behavior","identifiers":["doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class","doc:\/\/Braze\/documentation\/BrazeKit\/BrazeDelegate","doc:\/\/Braze\/documentation\/BrazeKit\/overrideResourceBundle"],"generated":true}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In "},{"code":"BrazeKit","type":"codeVoice"},{"type":"text","text":", a user can be identified using one of two device ID options:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Apple’s ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/uidevice\/1620059-identifierforvendor"},{"text":" property.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A randomly generated UUID."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Because ","type":"text"},{"type":"codeVoice","code":"identifierForVendor"},{"text":" may not be available in all scenarios or devices, Braze provides the option to use a more generic UUID to identify a user’s device.","type":"text"}]},{"level":2,"text":"Setting Your Configuration","type":"heading","anchor":"Setting-Your-Configuration"},{"type":"paragraph","inlineContent":[{"text":"To configure this option, set ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId"},{"type":"text","text":" under "},{"type":"codeVoice","code":"Braze.Configuration"},{"type":"text","text":". Assigning this property to "},{"type":"codeVoice","code":"true"},{"text":" will generate a random UUID for each user installation, whereas a value of ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" will notify the SDK to use the device’s ","type":"text"},{"code":"identifierForVendor","type":"codeVoice"},{"type":"text","text":"."}]},{"syntax":"swift","code":["let configuration = Braze.Configuration(","    apiKey: \"<BRAZE_API_KEY>\",","    endpoint: \"<BRAZE_ENDPOINT>\"",")","\/\/ Set this value to `true` to opt out of `identifierForVendor` usage.","configuration.useUUIDAsDeviceId = true","let braze = Braze(configuration: configuration)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Starting in 7.0.0, the default value for this property is "},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"For device types that do not support ","type":"text"},{"code":"identifierForVendor","type":"codeVoice"},{"type":"text","text":", such as watchOS or macOS, Braze will default to a randomly generated UUID regardless of which option is configured."}]}]},{"inlineContent":[{"type":"text","text":"After being generated, device IDs created from UUIDs will remain consistent throughout the lifetime of the application’s installation or until "},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/wipeData()","isActive":true,"type":"reference"},{"text":" is called.","type":"text"}],"type":"paragraph"},{"type":"aside","style":"important","name":"Important","content":[{"inlineContent":[{"type":"text","text":"Since calling "},{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/wipeData()","isActive":true},{"text":" will erase all local SDK storage, the device ID that was previously stored will be deleted. Thus, if ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId"},{"text":" is enabled, the SDK will generate a new UUID for the device ID after this operation. Similarly, if ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId"},{"text":" is disabled, the SDK will re-use the same IDFV after this operation.","type":"text"}],"type":"paragraph"}]},{"level":2,"type":"heading","anchor":"Migrating-from-a-Previous-Version","text":"Migrating from a Previous Version"},{"inlineContent":[{"type":"text","text":"If you are migrating your project from the legacy "},{"type":"reference","identifier":"https:\/\/github.com\/Appboy\/appboy-ios-sdk","isActive":true},{"type":"text","text":" or from a version of the Braze Swift SDK prior to "},{"code":"5.7.0","type":"codeVoice"},{"text":", note that the ","type":"text"},{"type":"codeVoice","code":"identifierForVendor"},{"type":"text","text":" option will be used by default, regardless of the configuration setting. This ensures continuity for any anonymous users previously identified by the "},{"type":"codeVoice","code":"identifierForVendor"},{"text":" device ID.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In such cases, if you wish to override those pre-existing values and ensure that your ","type":"text"},{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId","isActive":true},{"text":" configuration is respected, call ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/wipeData()"},{"text":" on the ","type":"text"},{"type":"codeVoice","code":"Braze"},{"text":" instance after migrating to any version of the Braze Swift SDK from ","type":"text"},{"code":"5.7.0","type":"codeVoice"},{"text":" onwards.","type":"text"}]}]}],"identifier":{"i