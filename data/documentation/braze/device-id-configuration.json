{"identifier":{"url":"doc:\/\/Braze\/documentation\/Braze\/device-id-configuration","interfaceLanguage":"swift"},"abstract":[{"text":"Configuring your user’s device ID with ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId","type":"reference"},{"text":".","type":"text"}],"sections":[],"seeAlsoSections":[{"generated":true,"anchor":"Customize-Behavior","identifiers":["doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class","doc:\/\/Braze\/documentation\/BrazeKit\/BrazeDelegate","doc:\/\/Braze\/documentation\/BrazeKit\/overrideResourceBundle"],"title":"Customize Behavior"}],"kind":"article","metadata":{"modules":[{"name":"BrazeKit"}],"role":"article","roleHeading":"Article","title":"Device ID Configuration"},"hierarchy":{"paths":[["doc:\/\/Braze\/documentation\/BrazeKit"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"text":"In ","type":"text"},{"type":"codeVoice","code":"BrazeKit"},{"text":", a user can be identified using one of two device ID options:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Apple’s ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/uidevice\/1620059-identifierforvendor","isActive":true,"type":"reference"},{"text":" property.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A randomly generated UUID.","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"Because "},{"code":"identifierForVendor","type":"codeVoice"},{"type":"text","text":" may not be available in all scenarios or devices, Braze provides the option to use a more generic UUID to identify a user’s device."}],"type":"paragraph"},{"anchor":"Setting-Your-Configuration","level":2,"type":"heading","text":"Setting Your Configuration"},{"inlineContent":[{"type":"text","text":"To configure this option, set "},{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId","isActive":true},{"type":"text","text":" under "},{"type":"codeVoice","code":"Braze.Configuration"},{"type":"text","text":". Assigning this property to "},{"type":"codeVoice","code":"true"},{"type":"text","text":" will generate a random UUID for each user installation, whereas a value of "},{"type":"codeVoice","code":"false"},{"type":"text","text":" will notify the SDK to use the device’s "},{"type":"codeVoice","code":"identifierForVendor"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","code":["let configuration = Braze.Configuration(","    apiKey: \"<BRAZE_API_KEY>\",","    endpoint: \"<BRAZE_ENDPOINT>\"",")","\/\/ Set this value to `true` to opt out of `identifierForVendor` usage.","configuration.useUUIDAsDeviceId = true","let braze = Braze(configuration: configuration)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Starting in 7.0.0, the default value for this property is "},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"For device types that do not support "},{"type":"codeVoice","code":"identifierForVendor"},{"type":"text","text":", such as watchOS or macOS, Braze will default to a randomly generated UUID regardless of which option is configured."}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"},{"inlineContent":[{"text":"After being generated, device IDs created from UUIDs will remain consistent throughout the lifetime of the application’s installation or until ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/wipeData()","type":"reference"},{"text":" is called.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Since calling "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/wipeData()"},{"type":"text","text":" will erase all local SDK storage, the device ID that was previously stored will be deleted. Thus, if "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId"},{"type":"text","text":" is enabled, the SDK will generate a new UUID for the device ID after this operation. Similarly, if "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId"},{"type":"text","text":" is disabled, the SDK will re-use the same IDFV after this operation."}]}],"style":"important","type":"aside","name":"Important"},{"anchor":"Migrating-from-a-Previous-Version","text":"Migrating from a Previous Version","type":"heading","level":2},{"inlineContent":[{"text":"If you are migrating your project from the legacy ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Appboy\/appboy-ios-sdk"},{"text":" or from a version of the Braze Swift SDK prior to ","type":"text"},{"code":"5.7.0","type":"codeVoice"},{"text":", note that the ","type":"text"},{"code":"identifierForVendor","type":"codeVoice"},{"text":" option will be used by default, regardless of the configuration setting. This ensures continuity for any anonymous users previously identified by the ","type":"text"},{"code":"identifierForVendor","type":"codeVoice"},{"text":" device ID.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In such cases, if you wish to override those pre-existing values and ensure that your ","type":"text"},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId","type":"reference","isActive":true},{"text":" configuration is respected, call ","type":"text"},{"identi