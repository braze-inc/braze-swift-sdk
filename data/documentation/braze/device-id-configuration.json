{"metadata":{"role":"article","modules":[{"name":"BrazeKit"}],"roleHeading":"Article","title":"Device ID Configuration"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"inlineContent":[{"text":"In ","type":"text"},{"type":"codeVoice","code":"BrazeKit"},{"text":", a user can be identified using one of two device ID options:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Apple’s ","type":"text"},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/uidevice\/1620059-identifierforvendor","isActive":true},{"type":"text","text":" property."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A randomly generated UUID."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Because ","type":"text"},{"type":"codeVoice","code":"identifierForVendor"},{"type":"text","text":" may not be available in all scenarios or devices, Braze provides the option to use a more generic UUID to identify a user’s device."}]},{"anchor":"Setting-Your-Configuration","level":2,"text":"Setting Your Configuration","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"To configure this option, set ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId"},{"text":" under ","type":"text"},{"code":"Braze.Configuration","type":"codeVoice"},{"text":". Assigning this property to ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" will generate a random UUID for each user installation, whereas a value of "},{"type":"codeVoice","code":"false"},{"text":" will notify the SDK to use the device’s ","type":"text"},{"type":"codeVoice","code":"identifierForVendor"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["let configuration = Braze.Configuration(","    apiKey: \"<BRAZE_API_KEY>\",","    endpoint: \"<BRAZE_ENDPOINT>\"",")","\/\/ Set this value to `true` to opt out of `identifierForVendor` usage.","configuration.useUUIDAsDeviceId = true","let braze = Braze(configuration: configuration)"]},{"type":"paragraph","inlineContent":[{"text":"Starting in 7.0.0, the default value for this property is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":".","type":"text"}]},{"name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"For device types that do not support "},{"code":"identifierForVendor","type":"codeVoice"},{"text":", such as watchOS or macOS, Braze will default to a randomly generated UUID regardless of which option is configured.","type":"text"}],"type":"paragraph"}],"type":"aside"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After being generated, device IDs created from UUIDs will remain consistent throughout the lifetime of the application’s installation or until "},{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/wipeData()","isActive":true},{"type":"text","text":" is called."}]},{"style":"important","type":"aside","content":[{"inlineContent":[{"text":"Since calling ","type":"text"},{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/wipeData()","isActive":true},{"text":" will erase all local SDK storage, the device ID that was previously stored will be deleted. Thus, if ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId","type":"reference"},{"type":"text","text":" is enabled, the SDK will generate a new UUID for the device ID after this operation. Similarly, if "},{"isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId","type":"reference"},{"type":"text","text":" is disabled, the SDK will re-use the same IDFV after this operation."}],"type":"paragraph"}],"name":"Important"},{"level":2,"anchor":"Migrating-from-a-Previous-Version","type":"heading","text":"Migrating from a Previous Version"},{"inlineContent":[{"type":"text","text":"If you are migrating your project from the legacy "},{"identifier":"https:\/\/github.com\/Appboy\/appboy-ios-sdk","type":"reference","isActive":true},{"type":"text","text":" or from a version of the Braze Swift SDK prior to "},{"code":"5.7.0","type":"codeVoice"},{"type":"text","text":", note that the "},{"type":"codeVoice","code":"identifierForVendor"},{"type":"text","text":" option will be used by default, regardless of the configuration setting. This ensures continuity for any anonymous users previously identified by the "},{"code":"identifierForVendor","type":"codeVoice"},{"type":"text","text":" device ID."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In such cases, if you wish to override those pre-existing values and ensure that your "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId"},{"text":" configuration is respected, call ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/wipeData()"},{"type":"text","text":" on the "},{"type":"codeVoice","code":"Braze"},{"type":"text","text":" instance after migrating to any version of the Braze Swift SDK from "},{"code":"5.7.0","type":"codeVoice"},{"text":" onwards.","type":"text"}],"type":"paragraph"}]}],"sections":[],"kind":"article","hierarchy":{"paths":[["doc:\/\/Braze\/documentation\/BrazeKit"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Configuring your user’s device ID with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId"},{"type":"text","text":"."}],"seeAlsoSections":[{"anchor":"Customize-Behavior","identifie