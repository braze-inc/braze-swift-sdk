{"sections":[],"hierarchy":{"paths":[["doc:\/\/Braze\/documentation\/BrazeKit"]]},"abstract":[{"text":"Configuring your user’s device ID with ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId"},{"text":".","type":"text"}],"seeAlsoSections":[{"title":"Customize Behavior","generated":true,"anchor":"Customize-Behavior","identifiers":["doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class","doc:\/\/Braze\/documentation\/BrazeKit\/BrazeDelegate","doc:\/\/Braze\/documentation\/BrazeKit\/overrideResourceBundle"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"role":"article","title":"Device ID Configuration","roleHeading":"Article","modules":[{"name":"BrazeKit"}]},"identifier":{"url":"doc:\/\/Braze\/documentation\/Braze\/device-id-configuration","interfaceLanguage":"swift"},"kind":"article","primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In "},{"type":"codeVoice","code":"BrazeKit"},{"type":"text","text":", a user can be identified using one of two device ID options:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Apple’s "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/uidevice\/1620059-identifierforvendor"},{"type":"text","text":" property."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A randomly generated UUID.","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because "},{"type":"codeVoice","code":"identifierForVendor"},{"type":"text","text":" may not be available in all scenarios or devices, Braze provides the option to use a more generic UUID to identify a user’s device."}]},{"level":2,"anchor":"Setting-Your-Configuration","type":"heading","text":"Setting Your Configuration"},{"type":"paragraph","inlineContent":[{"text":"To configure this option, set ","type":"text"},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId","isActive":true,"type":"reference"},{"text":" under ","type":"text"},{"code":"Braze.Configuration","type":"codeVoice"},{"text":". Assigning this property to ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" will generate a random UUID for each user installation, whereas a value of ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" will notify the SDK to use the device’s ","type":"text"},{"code":"identifierForVendor","type":"codeVoice"},{"text":".","type":"text"}]},{"syntax":"swift","code":["let configuration = Braze.Configuration(","    apiKey: \"<BRAZE_API_KEY>\",","    endpoint: \"<BRAZE_ENDPOINT>\"",")","\/\/ Set this value to `true` to opt out of `identifierForVendor` usage.","configuration.useUUIDAsDeviceId = true","let braze = Braze(configuration: configuration)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Starting in 7.0.0, the default value for this property is "},{"code":"true","type":"codeVoice"},{"type":"text","text":"."}]},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For device types that do not support "},{"type":"codeVoice","code":"identifierForVendor"},{"type":"text","text":", such as watchOS or macOS, Braze will default to a randomly generated UUID regardless of which option is configured."}]}],"type":"aside"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After being generated, device IDs created from UUIDs will remain consistent throughout the lifetime of the application’s installation or until "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/wipeData()"},{"type":"text","text":" is called."}]},{"name":"Important","style":"important","content":[{"inlineContent":[{"type":"text","text":"Since calling "},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/wipeData()","type":"reference","isActive":true},{"type":"text","text":" will erase all local SDK storage, the device ID that was previously stored will be deleted. Thus, if "},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId","type":"reference","isActive":true},{"type":"text","text":" is enabled, the SDK will generate a new UUID for the device ID after this operation. Similarly, if "},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId","type":"reference","isActive":true},{"type":"text","text":" is disabled, the SDK will re-use the same IDFV after this operation."}],"type":"paragraph"}],"type":"aside"},{"text":"Migrating from a Previous Version","type":"heading","level":2,"anchor":"Migrating-from-a-Previous-Version"},{"inlineContent":[{"text":"If you are migrating your project from the legacy ","type":"text"},{"identifier":"https:\/\/github.com\/Appboy\/appboy-ios-sdk","isActive":true,"type":"reference"},{"text":" or from a version of the Braze Swift SDK prior to ","type":"text"},{"type":"codeVoice","code":"5.7.0"},{"text":", note that the ","type":"text"},{"type":"codeVoice","code":"identifierForVendor"},{"text":" option will be used by default, regardless of the configuration setting. This ensures continuity for any anonymous users previously identified by the ","type":"text"},{"type":"codeVoice","code":"identifierForVendor"},{"text":" device ID.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In such cases, if you wish to override those pre-existing values and ensure that your ","type":"text"},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId","isActive":true,"type":"reference"},{"text":" configuration is respected, call ","type":"text"},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/wipeData()","isActive":true,"type":"reference"},{"text":" on the ","type":"text"},{"code":"Braze","type":"codeVoice"},{"text":" instance after migrating to any version of the Braze Swift SDK from ","type":"text"},{"code":"5.7.0","type":"codeVoice"},{"text":" onwards.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://Braze/documentation/BrazeKit/Braze":{"navigatorTitle":[{"text":"Braze","kind":"identifier"}],"title":"Braze","role":"symbol","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze","abstract":[{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze","isActive":true,"type":"reference"},{"text":" is the main entry point of the BrazeKit module and provides access to all its features.","type":"text"}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Braze","kind":"identifier"}],"type":"topic","url":"\/documentation\/brazekit\/braze"},"https://developer.apple.com/documentation/uikit/uidevice/1620059-identifierforvendor":{"title":"UIDevice.identifierForVendor","url":"https:\/\/developer.apple.com\/documentation\/uikit\/uidevice\/1620059-identifierforvendor","type":"link","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/uidevice\/1620059-identifierforvendor","titleInlineContent":[{"code":"UIDevice.identifierForVendor","type":"codeVoice"}]},"doc://Braze/documentation/BrazeKit":{"url":"\/documentation\/brazekit","kind":"symbol","abstract":[{"text":"The main Braze framework providing user sessions, attributes and events logging, push notification support.","type":"text"}],"identifier":"doc:\/\/Braze\/documentation\/BrazeKit","role":"collection","type":"topic","title":"BrazeKit"},"https://github.com/Appboy/appboy-ios-sdk":{"titleInlineContent":[{"type":"text","text":"AppboyKit SDK"}],"identifier":"https:\/\/github.com\/Appboy\/appboy-ios-sdk","type":"link","title":"AppboyKit SDK","url":"https:\/\/github.com\/Appboy\/appboy-i