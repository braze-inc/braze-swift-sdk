{"hierarchy":{"paths":[["doc:\/\/Braze\/documentation\/BrazeKit"]]},"identifier":{"url":"doc:\/\/Braze\/documentation\/Braze\/device-id-configuration","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Configuring your user’s device ID with "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId"},{"type":"text","text":"."}],"sections":[],"metadata":{"role":"article","title":"Device ID Configuration","roleHeading":"Article","modules":[{"name":"BrazeKit"}]},"seeAlsoSections":[{"generated":true,"anchor":"Customize-Behavior","identifiers":["doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class","doc:\/\/Braze\/documentation\/BrazeKit\/BrazeDelegate","doc:\/\/Braze\/documentation\/BrazeKit\/overrideResourceBundle"],"title":"Customize Behavior"}],"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"inlineContent":[{"type":"text","text":"In "},{"type":"codeVoice","code":"BrazeKit"},{"type":"text","text":", a user can be identified using one of two device ID options:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Apple’s ","type":"text"},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/uidevice\/1620059-identifierforvendor","isActive":true},{"text":" property.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A randomly generated UUID.","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Because ","type":"text"},{"code":"identifierForVendor","type":"codeVoice"},{"text":" may not be available in all scenarios or devices, Braze provides the option to use a more generic UUID to identify a user’s device.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Setting-Your-Configuration","text":"Setting Your Configuration"},{"inlineContent":[{"text":"To configure this option, set ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId","type":"reference"},{"text":" under ","type":"text"},{"code":"Braze.Configuration","type":"codeVoice"},{"text":". Assigning this property to ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" will generate a random UUID for each user installation, whereas a value of ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" will notify the SDK to use the device’s ","type":"text"},{"code":"identifierForVendor","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"code":["let configuration = Braze.Configuration(","    apiKey: \"<BRAZE_API_KEY>\",","    endpoint: \"<BRAZE_ENDPOINT>\"",")","\/\/ Set this value to `true` to opt out of `identifierForVendor` usage.","configuration.useUUIDAsDeviceId = true","let braze = Braze(configuration: configuration)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Starting in 7.0.0, the default value for this property is "},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"inlineContent":[{"text":"For device types that do not support ","type":"text"},{"code":"identifierForVendor","type":"codeVoice"},{"text":", such as watchOS or macOS, Braze will default to a randomly generated UUID regardless of which option is configured.","type":"text"}],"type":"paragraph"}],"type":"aside"},{"inlineContent":[{"text":"After being generated, device IDs created from UUIDs will remain consistent throughout the lifetime of the application’s installation or until ","type":"text"},{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/wipeData()","isActive":true},{"text":" is called.","type":"text"}],"type":"paragraph"},{"style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Since calling "},{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/wipeData()","isActive":true},{"type":"text","text":" will erase all local SDK storage, the device ID that was previously stored will be deleted. Thus, if "},{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId","isActive":true},{"type":"text","text":" is enabled, the SDK will generate a new UUID for the device ID after this operation. Similarly, if "},{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId","isActive":true},{"type":"text","text":" is disabled, the SDK will re-use the same IDFV after this operation."}]}],"type":"aside"},{"level":2,"type":"heading","anchor":"Migrating-from-a-Previous-Version","text":"Migrating from a Previous Version"},{"type":"paragraph","inlineContent":[{"text":"If you are migrating your project from the legacy ","type":"text"},{"identifier":"https:\/\/github.com\/Appboy\/appboy-ios-sdk","type":"reference","isActive":true},{"text":" or from a version of the Braze Swift SDK prior to ","type":"text"},{"code":"5.7.0","type":"codeVoice"},{"text":", note that the ","type":"text"},{"code":"identifierForVendor","type":"codeVoice"},{"text":" option will be used by default, regardless of the configuration setting. This ensures continuity for any anonymous users previously identified by the ","type":"text"},{"code":"identifierForVendor","type":"codeVoice"},{"text":" device ID.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In such cases, if you wish to override those pre-existing values and ensure that your ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/useUUIDAsDeviceId"},{"text":" configuration is respected, call ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/wipeData()"},{"text":" on the ","type":"text"},{"type":"codeVoice","code":"Braze"},{"text":" instance after migrating to any version of the Braze Swift SDK from ","type":"text"},{"type":"codeVoice","code":"5.7.0"},{"text":" onwards.","type":"text"}]}],"kind":"content"}],"references":{"https://github.com/Appboy/appboy-ios-sdk":{"url":"https:\/\/github.com\/Appboy\/appboy-ios-sdk","type":"link","titleInlineContent":[{"type":"text","text":"AppboyKit SDK"}],"identifier":"https:\/\/github.com\/Appboy\/appboy-ios-sdk","title":"AppboyKit SDK"},"https://developer.apple.com/documentation/uikit/uidevice/1620059-identifierforvendor":{"title":"UIDevice.identifierForVendor","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/uidevice\/1620059-identifierforvendor","titleInlineContent":[{"code":"UIDevice.identifierForVendor","type":"codeVoice"}],"url":"https:\/\/developer.apple.com\/documentation\/uikit\/uidevice\/1620059-identifierforvendor","type":"link"},"doc://Braze/documentation/BrazeKit":{"type":"topic","kind":"symbol","title":"BrazeKit","role":"collection","abstract":[{"text":"The main Braze framework providing user sessions, attributes and events logging, push notification support.","type":"text"}],"url":"\/documentation\/brazekit","identifier":"doc:\/\/Braze\/documentation\/BrazeKit"},"doc://Braze/documentation/BrazeKit/Braze/enabled":{"title":"enabled","kind":"symbol","url":"\/documentation\/brazekit\/braze\/enabled","type":"topic","abstract":[{"type":"text","text":"Specify whether the Braze SDK is enabled or not."}],"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/enabled","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"enabled"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}]},"doc://Braze/documentation/BrazeKit/Braze":{"kind":"symbol","a