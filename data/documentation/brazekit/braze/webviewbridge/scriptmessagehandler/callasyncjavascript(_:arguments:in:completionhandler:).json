{"kind":"symbol","metadata":{"externalID":"s:8BrazeKit0A0C13WebViewBridgeO20ScriptMessageHandlerC013callAsyncJavaF0_9arguments2in010completionH0ySS_SDySSypGSo05WKWebD0Cys6ResultOyypAG5ErrorOGcSgtF","title":"callAsyncJavaScript(_:arguments:in:completionHandler:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"callAsyncJavaScript","kind":"identifier"},{"text":"(","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"text":"arguments","kind":"externalParam"},{"text":": [","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":" : ","kind":"text"},{"text":"Any","kind":"keyword"},{"text":"], ","kind":"text"},{"text":"in","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"WKWebView","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)WKWebView"},{"text":", ","kind":"text"},{"text":"completionHandler","kind":"externalParam"},{"text":": (@","kind":"text"},{"text":"MainActor","kind":"typeIdentifier","preciseIdentifier":"s:ScM"},{"text":" (","kind":"text"},{"text":"Result","kind":"typeIdentifier","preciseIdentifier":"s:s6ResultO"},{"text":"<","kind":"text"},{"text":"Any","kind":"keyword"},{"text":", ","kind":"text"},{"text":"Error","kind":"typeIdentifier","preciseIdentifier":"s:8BrazeKit0A0C13WebViewBridgeO20ScriptMessageHandlerC5ErrorO"},{"text":">) -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":")?)","kind":"text"}],"symbolKind":"method","modules":[{"name":"BrazeKit"}],"roleHeading":"Instance Method","role":"symbol"},"sections":[],"hierarchy":{"paths":[["doc:\/\/Braze\/documentation\/BrazeKit","doc:\/\/Braze\/documentation\/BrazeKit\/Braze","doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge","doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler"]]},"variants":[{"paths":["\/documentation\/brazekit\/braze\/webviewbridge\/scriptmessagehandler\/callasyncjavascript(_:arguments:in:completionhandler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler\/callAsyncJavaScript(_:arguments:in:completionHandler:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"callAsyncJavaScript","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"functionBody","kind":"internalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":", "},{"kind":"externalParam","text":"arguments"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":" : "},{"kind":"keyword","text":"Any"},{"kind":"text","text":"] = [:], "},{"kind":"externalParam","text":"in"},{"kind":"text","text":" "},{"kind":"internalParam","text":"webView"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)WKWebView","text":"WKWebView"},{"kind":"text","text":", "},{"kind":"externalParam","text":"completionHandler"},{"kind":"text","text":": (@"},{"kind":"typeIdentifier","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","preciseIdentifier":"s:s6ResultO","text":"Result"},{"kind":"text","text":"<"},{"kind":"keyword","text":"Any"},{"kind":"text","text":", "},{"kind":"typeIdentifier","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler\/Error","preciseIdentifier":"s:8BrazeKit0A0C13WebViewBridgeO20ScriptMessageHandlerC5ErrorO","text":"Error"},{"kind":"text","text":">) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":")? = nil)"}]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The JavaScript string to use as the function body. This method treats","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the string as an anonymous JavaScript function body and calls it with"},{"type":"text","text":" "},{"type":"text","text":"the named arguments in the "},{"type":"codeVoice","code":"arguments"},{"type":"text","text":" parameter."}]}],"name":"functionBody"},{"content":[{"inlineContent":[{"type":"text","text":"A dictionary of the arguments to pass to the function call. Each key in the"},{"type":"text","text":" "},{"type":"text","text":"dictionary corresponds to the name of an argument in the functionBody"},{"type":"text","text":" "},{"type":"text","text":"string, and the value of that key is the value to use during the evaluation"},{"type":"text","text":" "},{"type":"text","text":"of the code. Supported value types are "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":", "},{"type":"codeVoice","code":"NSString"},{"type":"text","text":", "},{"type":"codeVoice","code":"NSArray"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"NSDictionary"},{"type":"text","text":", or "},{"type":"codeVoice","code":"NSNull"},{"type":"text","text":". All items in an array or dictionary must also"},{"type":"text","text":" "},{"type":"text","text":"be one of the supported types."}],"type":"paragraph"}],"name":"arguments"},{"content":[{"inlineContent":[{"type":"text","text":"The web view in which the JavaScript function is executed. The web view must"},{"type":"text","text":" "},{"type":"text","text":"implement the "},{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}],"name":"webView"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A handler block to execute when script evaluation finishes. The"},{"type":"text","text":" "},{"type":"text","text":"method calls your block whether script evaluation completes"},{"type":"text","text":" "},{"type":"text","text":"successfully or fails. The block has no return value and takes the"},{"type":"text","text":" "},{"type":"text","text":"following parameter:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"result: The result of the script evaluation, or an error object that contains","type":"text"},{"text":" ","type":"text"},{"text":"information about the problem that occurred. If your function body doesn’t","type":"text"},{"text":" ","type":"text"},{"text":"return an explicit value, WebKit passes ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" to your completion handler on","type":"text"},{"text":" ","type":"text"},{"text":"success. If your function explicitly returns null, WebKit returns that value","type":"text"},{"text":" ","type":"text"},{"text":"as an ","type":"text"},{"type":"codeVoice","code":"NSNull"},{"type":"text","text":" object."}]}]}]}],"name":"completionHandler"}],"kind":"parameters"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"content":[{"inlineContent":[{"text":"This function is a backport of the","type":"text"},{"text":" ","type":"text"},{"code":"WKWebView.callAsyncJavaScript(_:arguments:in:completionHandler:)","type":"codeVoice"},{"text":" method. It relies on","type":"text"},{"text":" ","type":"text"},{"text":"the script message handler to pass the result or error to the native side","type":"text"},{"text":" ","type":"text"},{"text":"asynchronously.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It differs from the WebKit method in the following ways:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"No support for passing ","type":"text"},{"code":"NSDate","type":"codeVoice"},{"text":" as an argument.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Errors are not wrapped in a "},{"type":"codeVoice","code":"WKError"},{"type":"text","text":" object."}]}]}],"type":"unorderedList"}],"style":"note","name":"Note","type":"aside"},{"inlineContent":[{"type":"text","text":"Don’t format the string in the "},{"type":"codeVoice","code":"functionBody"},{"type":"text","text":" parameter as a function-like callable"},{"type":"text","text":" "},{"type":"text","text":"object, as you would in pure JavaScript. Instead, put only the body of the function in the"},{"type":"text","text":" "},{"type":"text","text":"string. For example, the following string shows a valid function body that takes x, y, and"},{"type":"text","text":" "},{"type":"text","text":"z arguments and returns a result."}],"type":"paragraph"},{"syntax":"js","code":["return x ? y : z"],"type":"codeListing"},{"inlineContent":[{"text":"If your JavaScript code returns an object with a callable ","type":"text"},{"code":"then","type":"codeVoice"},{"text":" property, the function","type":"text"},{"text":" ","type":"text"},{"text":"calls that property on the resulting object and waits for its resolution. If resolution","type":"text"},{"text":" ","type":"text"},{"text":"succeeds, the function passes the resulting object to your completion handler. If","type":"text"},{"text":" ","type":"text"},{"text":"resolution fails, the function returns an error to your completion handler.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Because this method calls your JavaScript code asynchronously, you can call "},{"type":"codeVoice","code":"await"},{"type":"text","text":" on"},{"type":"text","text":" "},{"type":"text","text":"objects with a then property inside your function body. The following code example"},{"type":"text","text":" "},{"type":"text","text":"illustrates this technique."}],"type":"paragraph"},{"syntax":"js","code":["var p = new Promise(function (f) {","  window.setTimeout(\"f(42)\", 1000);","});","await p;","return p;"],"type":"codeListing"}],"kind":"content"}],"abstract":[{"type":"text","text":"Executes the specified string as an asynchronous JavaScript function."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://Braze/documentation/BrazeKit/Braze":{"kind":"symbol","abstract":[{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze","isActive":true},{"type":"text","text":" is the main entry point of the BrazeKit module and provides access to all its features."}],"title":"Braze","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze","navigatorTitle":[{"kind":"identifier","text":"Braze"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Braze"}],"role":"symbol","url":"\/documentation\/brazekit\/braze","type":"topic"},"doc://Braze/documentation/BrazeKit/Braze/WebViewBridge/ScriptMessageHandler/callAsyncJavaScript(_:arguments:in:completionHandler:)":{"abstract":[{"type":"text","text":"Executes the specified string as an asynchronous JavaScript function."}],"type":"topic","url":"\/documentation\/brazekit\/braze\/webviewbridge\/scriptmessagehandler\/callasyncjavascript(_:arguments:in:completionhandler:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"callAsyncJavaScript"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"arguments"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":" : "},{"kind":"keyword","text":"Any"},{"kind":"text","text":"], "},{"kind":"externalParam","text":"in"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)WKWebView","text":"WKWebView"},{"kind":"text","text":", "},{"kind":"externalParam","text":"completionHandler"},{"kind":"text","text":": (@"},{"kind":"typeIdentifier","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","preciseIdentifier":"s:s6ResultO","text":"Result"},{"kind":"text","text":"<"},{"kind":"keyword","text":"Any"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:8BrazeKit0A0C13WebViewBridgeO20ScriptMessageHandlerC5ErrorO","text":"Error"},{"kind":"text","text":">) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":")?)"}],"title":"callAsyncJavaScript(_:arguments:in:completionHandler:)","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler\/callAsyncJavaScript(_:arguments:in:completionHandler:)","kind":"symbol"},"doc://Braze/documentation/BrazeKit/Braze/WebViewBridge/ScriptMessageHandler/Error":{"title":"Braze.WebViewBridge.ScriptMessageHandler.Error","navigatorTitle":[{"kind":"identifier","text":"Error"}],"abstract":[],"kind":"symbol","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler\/Error","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Error"}],"url":"\/documentation\/brazekit\/braze\/webviewbridge\/scriptmessagehandler\/error","type":"topic","role":"symbol"},"doc://Braze/documentation/BrazeKit/Braze/WebViewBridge":{"title":"Braze.WebViewBridge","kind":"symbol","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge","role":"symbol","type":"topic","url":"\/documentation\/brazekit\/braze\/webviewbridge","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"WebViewBridge","kind":"identifier"}],"abstract":[],"navigatorTitle":[{"text":"WebViewBridge","kind":"identifier"}]},"doc://Braze/documentation/BrazeKit/Braze/WebViewBridge/ScriptMessageHandler":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ScriptMessageHandler","kind":"identifier"}],"url":"\/documentation\/brazekit\/braze\/webviewbridge\/scriptmessagehandler","title":"Braze.WebViewBridge.ScriptMessageHandler","type":"topic","navigatorTitle":[{"text":"ScriptMessageHandler","kind":"identifier"}],"abstract":[{"text":"Script message handler for the Braze WebView bridge.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler","role":"symbol"},"doc://Braze/documentation/BrazeKit":{"type":"topic","kind":"symbol","title":"BrazeKit","role":"collection","abstract":[{"text":"The main Braze framework providing user sessions, attributes and events logging, push notification support.","type":"text"}],"url":"\/documentation\/brazekit","identifier":"doc:\/\/Braze\/documentation\/BrazeKit"}}}