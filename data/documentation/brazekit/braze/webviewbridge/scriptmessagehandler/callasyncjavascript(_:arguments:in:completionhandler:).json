d":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The JavaScript string to use as the function body. This method treats"},{"type":"text","text":" "},{"type":"text","text":"the string as an anonymous JavaScript function body and calls it with"},{"text":" ","type":"text"},{"text":"the named arguments in the ","type":"text"},{"type":"codeVoice","code":"arguments"},{"type":"text","text":" parameter."}]}],"name":"functionBody"},{"name":"arguments","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A dictionary of the arguments to pass to the function call. Each key in the"},{"type":"text","text":" "},{"text":"dictionary corresponds to the name of an argument in the functionBody","type":"text"},{"text":" ","type":"text"},{"text":"string, and the value of that key is the value to use during the evaluation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of the code. Supported value types are "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"NSString"},{"type":"text","text":", "},{"code":"NSArray","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NSDictionary"},{"text":", or ","type":"text"},{"code":"NSNull","type":"codeVoice"},{"type":"text","text":". All items in an array or dictionary must also"},{"type":"text","text":" "},{"text":"be one of the supported types.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The web view in which the JavaScript function is executed. The web view must"},{"text":" ","type":"text"},{"type":"text","text":"implement the "},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler","isActive":true,"type":"reference"},{"text":".","type":"text"}]}],"name":"webView"},{"name":"completionHandler","content":[{"type":"paragraph","inlineContent":[{"text":"A handler block to execute when script evaluation finishes. The","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"method calls your block whether script evaluation completes"},{"type":"text","text":" "},{"text":"successfully or fails. The block has no return value and takes the","type":"text"},{"text":" ","type":"text"},{"text":"following parameter:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"result: The result of the script evaluation, or an error object that contains"},{"type":"text","text":" "},{"type":"text","text":"information about the problem that occurred. If your function body doesn’t"},{"type":"text","text":" "},{"text":"return an explicit value, WebKit passes ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to your completion handler on"},{"type":"text","text":" "},{"type":"text","text":"success. If your function explicitly returns null, WebKit returns that value"},{"text":" ","type":"text"},{"type":"text","text":"as an "},{"code":"NSNull","type":"codeVoice"},{"text":" object.","type":"text"}]}]}]}]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"This function is a backport of the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"WKWebView.callAsyncJavaScript(_:arguments:in:completionHandler:)"},{"text":" method. It relies on","type":"text"},{"text":" ","type":"text"},{"text":"the script message handler to pass the result or error to the native side","type":"text"},{"type":"text","text":" "},{"text":"asynchronously.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It differs from the WebKit method in the following ways:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"No support for passing "},{"code":"NSDate","type":"codeVoice"},{"text":" as an argument.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Errors are not wrapped in a "},{"type":"codeVoice","code":"WKError"},{"text":" object.","type":"text"}]}]}]}],"type":"aside"},{"type":"paragraph","inlineContent":[{"text":"Don’t format the string in the ","type":"text"},{"code":"functionBody","type":"codeVoice"},{"type":"text","text":" parameter as a function-like callable"},{"text":" ","type":"text"},{"text":"object, as you would in pure JavaScript. Instead, put only the body of the function in the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"string. For example, the following string shows a valid function body that takes x, y, and"},{"type":"text","text":" "},{"text":"z arguments and returns a result.","type":"text"}]},{"type":"codeListing","syntax":"js","code":["return x ? y : z"]},{"type":"paragraph","inlineContent":[{"text":"If your JavaScript code returns an object with a callable ","type":"text"},{"type":"codeVoice","code":"then"},{"type":"text","text":" property, the function"},{"text":" ","type":"text"},{"type":"text","text":"calls that property on the resulting object and waits for its resolution. If resolution"},{"type":"text","text":" "},{"type":"text","text":"succeeds, the function passes the resulting object to your completion handler. If"},{"type":"text","text":" "},{"text":"resolution fails, the function returns an error to your completion handler.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Because this method calls your JavaScript code asynchronously, you can call "},{"code":"await","type":"codeVoice"},{"type":"text","text":" on"},{"type":"text","text":" "},{"type":"text","text":"objects with a then property inside your function body. The following code example"},{"text":" ","type":"text"},{"type":"text","text":"illustrates this technique."}],"type":"paragraph"},{"syntax":"js","code":["var p = new Promise(function (f) {","  window.s