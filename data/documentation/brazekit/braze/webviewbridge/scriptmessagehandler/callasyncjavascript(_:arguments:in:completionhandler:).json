},{"text":")?)","kind":"text"}],"modules":[{"name":"BrazeKit"}],"role":"symbol","title":"callAsyncJavaScript(_:arguments:in:completionHandler:)"},"abstract":[{"text":"Executes the specified string as an asynchronous JavaScript function.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"callAsyncJavaScript","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"functionBody","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"text":", ","kind":"text"},{"text":"arguments","kind":"externalParam"},{"text":": [","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":" : ","kind":"text"},{"text":"Any","kind":"keyword"},{"text":"] = [:], ","kind":"text"},{"kind":"externalParam","text":"in"},{"kind":"text","text":" "},{"text":"webView","kind":"internalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"WKWebView","preciseIdentifier":"c:objc(cs)WKWebView"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"completionHandler"},{"text":": (@","kind":"text"},{"preciseIdentifier":"s:ScM","kind":"typeIdentifier","text":"MainActor"},{"kind":"text","text":" ("},{"preciseIdentifier":"s:s6ResultO","text":"Result","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Any","kind":"keyword"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"Error","preciseIdentifier":"s:8BrazeKit0A0C13WebViewBridgeO20ScriptMessageHandlerC5ErrorO","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler\/Error"},{"kind":"text","text":">) -> "},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":")? = nil)","kind":"text"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The JavaScript string to use as the function body. This method treats"},{"type":"text","text":" "},{"type":"text","text":"the string as an anonymous JavaScript function body and calls it with"},{"type":"text","text":" "},{"type":"text","text":"the named arguments in the "},{"type":"codeVoice","code":"arguments"},{"type":"text","text":" parameter."}],"type":"paragraph"}],"name":"functionBody"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A dictionary of the arguments to pass to the function call. Each key in the"},{"type":"text","text":" "},{"type":"text","text":"dictionary corresponds to the name of an argument in the functionBody"},{"type":"text","text":" "},{"type":"text","text":"string, and the value of that key is the value to use during the evaluation"},{"type":"text","text":" "},{"type":"text","text":"of the code. Supported value types are "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":", "},{"code":"NSString","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"NSArray"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSDictionary"},{"text":", or ","type":"text"},{"type":"codeVoice","code":"NSNull"},{"type":"text","text":". All items in an array or dictionary must also"},{"text":" ","type":"text"},{"type":"text","text":"be one of the supported types."}]}],"name":"arguments"},{"name":"webView","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The web view in which the JavaScript function is executed. The web view must"},{"text":" ","type":"text"},{"type":"text","text":"implement the "},{"isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler","type":"reference"},{"text":".","type":"text"}]}]},{"name":"completionHandler","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A handler block to execute when script evaluation finishes. The"},{"type":"text","text":" "},{"text":"method calls your block whether script evaluation completes","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"successfully or fails. The block has no return value and takes the"},{"type":"text","text":" "},{"type":"text","text":"following parameter:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"result: The result of the script evaluation, or an error object that contains","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"information about the problem that occurred. If your function body doesn’t"},{"text":" ","type":"text"},{"type":"text","text":"return an explicit value, WebKit passes "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" to your completion handler on"},{"text":" ","type":"text"},{"text":"success. If your function explicitly returns null, WebKit returns that value","type":"text"},{"type":"text","text":" "},{"text":"as an ","type":"text"},{"type":"codeVoice","code":"NSNull"},{"text":" object.","type":"text"}]}]}]}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This function is a backport of the"},{"text":" ","type":"text"},{"code":"WKWebView.callAsyncJavaScript(_:arguments:in:completionHandler:)","type":"codeVoice"},{"text":" method. It relies on","type":"text"},{"type":"text","text":" "},{"text":"the script message handler to pass the result or error to the native side","type":"text"},{"type":"text","text":" "},{"type":"text","text":"asynchronously."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It differs from the WebKit method in the following ways:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No support for passing "},{"type":"codeVoice","code":"NSDate"},{"text":" as an argument.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Errors are not wrapped in a ","type":"text"},{"type":"codeVoice","code":"WKError"},{"text":" object.","type":"text"}]}]}]}],"name":"Note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Don’t format the string in the "},{"code":"functionBody","type":"codeVoice"},{"type":"text","text":" parameter as a function-like callable"},{"type":"text","text":" "},{"type":"text","text":"object, as you would in pure JavaScript. Instead, put only the body of the function in the"},{"text":" ","type":"text"},{"text":"string. For example, the following string shows a valid function body that takes x, y, and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"z arguments and returns a result."}]},{"type":"codeListing","syntax":"js","code":["return x ? y : z"]},{"inlineContent":[{"text":"If your JavaScript code returns an object with a callable ","type":"text"},{"type":"codeVoice","code":"then"},{"text":" property, the function","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"calls that property on the resulting object and waits for its resolution. If resolution"},{"type":"text","text":" "},{"type":"text","text":"succeeds, the function passes the resulting object to your completion handler. If"},{"text":" ","type":"text"},{"type":"text","text":"resolution fails, the function returns an error to your completion handler."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because this method calls your JavaScript code asynchronously, you can call "},{"code":"await","type":"codeVoice"},{"text":" on","type":"text"},{"type":"text","text":" "},{"text":"objects with a then property inside your function body. The following code example","type":"text"},{"text":" ","type":"text"},{"text":"illustrates this technique.","type":"text"}]},{"type":"codeListing","syntax":"js","code":["var p = new Promise(function (f) {","  window.setTimeout(\"f(42)\", 1000);","});","await p;","return p;"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/brazekit\/braze\/webviewbridge\/scriptmessagehandler\/callasyncjavascript(_:arguments:in:completionhandler:)"]}],"references":{"doc://Braze/documentation/BrazeKit/Braze/WebViewBridge/ScriptMessageHandler/Error":{"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"text":"Error","kind":"identifier"}],"type":"topic","role":"symbol","abstract":[],"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler\/Error","kind":"symbol","title":"Braze.WebViewBridge.ScriptMessageHandler.Error","navigatorTitle":[{"text":"Error","kind":"identifier"}],"url":"\/documentation\/brazekit\/braze\/webviewbridge\/scriptmessagehandler\/error"},"doc://Braze/documentation/BrazeKit/Braze":{"url":"\/documentation\/brazekit\/braze","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze","navigatorTitle":[{"kind":"identifier","text":"Braze"}],"title":"Braze","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Braze","kind":"identifier"}],"type":"topic","role":"symbol","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze"},{"type":"text","text":" is the main entry point of the BrazeKit module and provides access to all its features."}]},"doc://Braze/documentation/BrazeKit/Braze/WebViewBridge":{"navigatorTitle":[{"kind":"identifier","text":"WebViewBridge"}],"title":"Braze.WebViewBridge","abstract":[],"role":"symbol","url":"\/documentation\/brazekit\/braze\/webviewbridge","kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"WebViewBridge"}],"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge","type":"topi