e":"functionBody","content":[{"inlineContent":[{"type":"text","text":"The JavaScript string to use as the function body. This method treats"},{"type":"text","text":" "},{"type":"text","text":"the string as an anonymous JavaScript function body and calls it with"},{"type":"text","text":" "},{"type":"text","text":"the named arguments in the "},{"type":"codeVoice","code":"arguments"},{"type":"text","text":" parameter."}],"type":"paragraph"}]},{"name":"arguments","content":[{"type":"paragraph","inlineContent":[{"text":"A dictionary of the arguments to pass to the function call. Each key in the","type":"text"},{"text":" ","type":"text"},{"text":"dictionary corresponds to the name of an argument in the functionBody","type":"text"},{"text":" ","type":"text"},{"text":"string, and the value of that key is the value to use during the evaluation","type":"text"},{"text":" ","type":"text"},{"text":"of the code. Supported value types are ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":", ","type":"text"},{"code":"NSString","type":"codeVoice"},{"text":", ","type":"text"},{"code":"NSArray","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"NSDictionary","type":"codeVoice"},{"text":", or ","type":"text"},{"code":"NSNull","type":"codeVoice"},{"text":". All items in an array or dictionary must also","type":"text"},{"text":" ","type":"text"},{"text":"be one of the supported types.","type":"text"}]}]},{"name":"webView","content":[{"inlineContent":[{"text":"The web view in which the JavaScript function is executed. The web view must","type":"text"},{"text":" ","type":"text"},{"text":"implement the ","type":"text"},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}]},{"name":"completionHandler","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A handler block to execute when script evaluation finishes. The"},{"type":"text","text":" "},{"type":"text","text":"method calls your block whether script evaluation completes"},{"type":"text","text":" "},{"type":"text","text":"successfully or fails. The block has no return value and takes the"},{"type":"text","text":" "},{"type":"text","text":"following parameter:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"result: The result of the script evaluation, or an error object that contains"},{"type":"text","text":" "},{"type":"text","text":"information about the problem that occurred. If your function body doesn’t"},{"type":"text","text":" "},{"type":"text","text":"return an explicit value, WebKit passes "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to your completion handler on"},{"type":"text","text":" "},{"type":"text","text":"success. If your function explicitly returns null, WebKit returns that value"},{"type":"text","text":" "},{"type":"text","text":"as an "},{"code":"NSNull","type":"codeVoice"},{"type":"text","text":" object."}],"type":"paragraph"}]}]}]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This function is a backport of the"},{"type":"text","text":" "},{"code":"WKWebView.callAsyncJavaScript(_:arguments:in:completionHandler:)","type":"codeVoice"},{"type":"text","text":" method. It relies on"},{"type":"text","text":" "},{"type":"text","text":"the script message handler to pass the result or error to the native side"},{"type":"text","text":" "},{"type":"text","text":"asynchronously."}]},{"type":"paragraph","inlineContent":[{"text":"It differs from the WebKit method in the following ways:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"No support for passing "},{"code":"NSDate","type":"codeVoice"},{"type":"text","text":" as an argument."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Errors are not wrapped in a "},{"code":"WKError","type":"codeVoice"},{"type":"text","text":" object."}]}]}]}],"type":"aside","style":"note","name":"Note"},{"inlineContent":[{"type":"text","text":"Don’t format the string in the "},{"type":"codeVoice","code":"functionBody"},{"type":"text","text":" parameter as a function-like callable"},{"type":"text","text":" "},{"type":"text","text":"object, as you would in pure JavaScript. Instead, put only the body of the function in the"},{"type":"text","text":" "},{"type":"text","text":"string. For example, the following string shows a valid function body that takes x, y, and"},{"type":"text","text":" "},{"type":"text","text":"z arguments and returns a result."}],"type":"paragraph"},{"syntax":"js","code":["return x ? y : z"],"type":"codeListing"},{"inlineContent":[{"text":"If your JavaScript code returns an object with a callable ","type":"text"},{"code":"then","type":"codeVoice"},{"text":" property, the function","type":"text"},{"text":" ","type":"text"},{"text":"calls that property on the resulting object and waits for its resolution. If resolution","type":"text"},{"text":" ","type":"text"},{"text":"succeeds, the function passes the resulting object to your completion handler. If","type":"text"},{"text":" ","type":"text"},{"text":"resolution fails, the function returns an error to your completion handler.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Because this method calls your JavaScript code asynchronously, you can call ","type":"text"},{"code":"await","type":"codeVoice"},{"text":" on","type":"text"},{"text":" ","type":"text"},{"text":"objects with a then property inside your function body. The following code example","type":"text"},{"text":" ","type":"text"},{"text":"illustrates this technique.","type":"text"}],"type":"paragraph"},{"syntax":"js","code":["var p = new Promise(function (f) {","  window.setTimeout(\"f(42)\", 1000);","});","await p;","return p;"],"type":"codeListing"}],"kind":"content"}],"abstract":[{"type":"text","text":"Executes the specified string as an asynchronous JavaScript function."}],"sections":[],"identifier":{"url":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler\/callAsyncJavaScript(_:arguments:in:completionHandler:)","interfaceLanguage":"swift"},"references":{"doc://Braze/documentation/BrazeKit/Braze/WebViewBridge":{"title":"Braze.WebViewBridge","kind":"symbol","role":"symbol","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge","url":"\/documentation\/brazekit\/braze\/webviewbridge","type":"topic","navigatorTitle":[{"kind":"identifier","text":"WebViewBridge"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"WebViewBridge"}],"abstract":[]},"doc://Braze/documentation/BrazeKit/Braze":{"navigatorTitle":[{"text":"Braze","kind":"identifier"}],"title":"Braze","role":"symbol","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze","abstract":[{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze","isActive":true,"type":"reference"},{"text":" is the main entry point of the BrazeKit module and provides access to all its features.","type":"text"}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Braze","kind":"identifier"}],"type":"topic","url":"\/documentation\/brazekit\/braze"},"doc://Braze/documentation/BrazeKit/Braze/WebViewBridge/ScriptMessageHandler":{"navigatorTitle":[{"kind":"identifier","text":"ScriptMessageHandler"}],"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler","role":"symbol","abstract":[{"type":"text","text":"Script message handler for the Braze WebView bridge."}],"kind":"symbol","title":"Braze.WebViewBridge.ScriptMessageHandler","type":"topic","url":"\/documentation\/brazekit\/braze\/webviewbridge\/scriptmessagehandler","fragments":[{"kind":"keyword","text":"cla