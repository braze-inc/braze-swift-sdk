"text":")? = nil)"}],"platforms":["iOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The JavaScript string to use as the function body. This method treats","type":"text"},{"text":" ","type":"text"},{"text":"the string as an anonymous JavaScript function body and calls it with","type":"text"},{"text":" ","type":"text"},{"text":"the named arguments in the ","type":"text"},{"code":"arguments","type":"codeVoice"},{"text":" parameter.","type":"text"}]}],"name":"functionBody"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A dictionary of the arguments to pass to the function call. Each key in the"},{"type":"text","text":" "},{"type":"text","text":"dictionary corresponds to the name of an argument in the functionBody"},{"type":"text","text":" "},{"type":"text","text":"string, and the value of that key is the value to use during the evaluation"},{"type":"text","text":" "},{"type":"text","text":"of the code. Supported value types are "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":", "},{"code":"NSString","type":"codeVoice"},{"type":"text","text":", "},{"code":"NSArray","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"NSDictionary","type":"codeVoice"},{"type":"text","text":", or "},{"code":"NSNull","type":"codeVoice"},{"type":"text","text":". All items in an array or dictionary must also"},{"type":"text","text":" "},{"type":"text","text":"be one of the supported types."}]}],"name":"arguments"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The web view in which the JavaScript function is executed. The web view must"},{"type":"text","text":" "},{"type":"text","text":"implement the "},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler","type":"reference","isActive":true},{"type":"text","text":"."}]}],"name":"webView"},{"content":[{"inlineContent":[{"type":"text","text":"A handler block to execute when script evaluation finishes. The"},{"type":"text","text":" "},{"type":"text","text":"method calls your block whether script evaluation completes"},{"type":"text","text":" "},{"type":"text","text":"successfully or fails. The block has no return value and takes the"},{"type":"text","text":" "},{"type":"text","text":"following parameter:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"result: The result of the script evaluation, or an error object that contains"},{"type":"text","text":" "},{"type":"text","text":"information about the problem that occurred. If your function body doesn’t"},{"type":"text","text":" "},{"type":"text","text":"return an explicit value, WebKit passes "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to your completion handler on"},{"type":"text","text":" "},{"type":"text","text":"success. If your function explicitly returns null, WebKit returns that value"},{"type":"text","text":" "},{"type":"text","text":"as an "},{"code":"NSNull","type":"codeVoice"},{"text":" object.","type":"text"}]}]}]}],"name":"completionHandler"}]},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"content":[{"inlineContent":[{"type":"text","text":"This function is a backport of the"},{"type":"text","text":" "},{"type":"codeVoice","code":"WKWebView.callAsyncJavaScript(_:arguments:in:completionHandler:)"},{"type":"text","text":" method. It relies on"},{"type":"text","text":" "},{"type":"text","text":"the script message handler to pass the result or error to the native side"},{"type":"text","text":" "},{"type":"text","text":"asynchronously."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It differs from the WebKit method in the following ways:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"No support for passing ","type":"text"},{"code":"NSDate","type":"codeVoice"},{"text":" as an argument.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Errors are not wrapped in a ","type":"text"},{"code":"WKError","type":"codeVoice"},{"text":" object.","type":"text"}],"type":"paragraph"}]}]}],"name":"Note","type":"aside","style":"note"},{"inlineContent":[{"type":"text","text":"Don’t format the string in the "},{"type":"codeVoice","code":"functionBody"},{"type":"text","text":" parameter as a function-like callable"},{"type":"text","text":" "},{"type":"text","text":"object, as you would in pure JavaScript. Instead, put only the body of the function in the"},{"type":"text","text":" "},{"type":"text","text":"string. For example, the following string shows a valid function body that takes x, y, and"},{"type":"text","text":" "},{"type":"text","text":"z arguments and returns a result."}],"type":"paragraph"},{"syntax":"js","code":["return x ? y : z"],"type":"codeListing"},{"inlineContent":[{"text":"If your JavaScript code returns an object with a callable ","type":"text"},{"code":"then","type":"codeVoice"},{"text":" property, the function","type":"text"},{"text":" ","type":"text"},{"text":"calls that property on the resulting object and waits for its resolution. If resolution","type":"text"},{"text":" ","type":"text"},{"text":"succeeds, the function passes the resulting object to your completion handler. If","type":"text"},{"text":" ","type":"text"},{"text":"resolution fails, the function returns an error to your completion handler.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Because this method calls your JavaScript code asynchronously, you can call "},{"type":"codeVoice","code":"await"},{"type":"text","text":" on"},{"type":"text","text":" "},{"type":"text","text":"objects with a then property inside your function body. The following code example"},{"type":"text","text":" "},{"type":"text","text":"illustrates this technique."}],"type":"paragraph"},{"syntax":"js","code":["var p = new Promise(function (f) {","  window.setTimeout(\"f(42)\", 1000);","});","await p;","return p;"],"type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/brazekit\/braze\/webviewbridge\/scriptmessagehandler\/callasyncjavascript(_:arguments:in:completionhandler:)"]}],"identifier":{"url":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler\/callAsyncJavaScript(_:arguments:in:completionHandler:)","interfaceLanguage":"swift"},"sections":[],"metadata":{"externalID":"s:8BrazeKit0A0C13WebViewBridgeO20ScriptMessageHandlerC013callAsyncJavaF0_9arguments2in010completionH0ySS_SDySSypGSo05WKWebD0Cys6ResultOyypAG5ErrorOGcSgtF","role":"symbol","symbolKind":"method","title":"callAsyncJavaScript(_:arguments:in:completionHandler:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"callAsyncJavaScript","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"arguments","kind":"externalParam"},{"text":": [","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Any","kind":"keyword"},{"text":"], ","kind":"text"},{"text":"in","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:objc(cs)WKWebView","text":"WKWebView","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"completionHandler","kind":"externalParam"},{"text":": (@","kind":"text"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"typeIdentifier"},{"text":" (","kind":"text"},{"preciseIdentifier":"s:s6ResultO","text":"Result","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Any","kind":"keyword"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:8BrazeKit0A0C13WebViewBridgeO20ScriptMessageHandlerC5ErrorO","text":"Error","kind":"typeIdentifier"},{"text":">