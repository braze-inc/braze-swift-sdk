ges":["swift"],"platforms":["iOS"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"callAsyncJavaScript"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"_"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"functionBody"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":", "},{"kind":"externalParam","text":"arguments"},{"text":": [","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"text":" : ","kind":"text"},{"text":"Any","kind":"keyword"},{"kind":"text","text":"] = [:], "},{"text":"in","kind":"externalParam"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"webView"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:objc(cs)WKWebView","text":"WKWebView","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"completionHandler"},{"kind":"text","text":": (@"},{"text":"MainActor","kind":"typeIdentifier","preciseIdentifier":"s:ScM"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","preciseIdentifier":"s:s6ResultO","text":"Result"},{"text":"<","kind":"text"},{"text":"Any","kind":"keyword"},{"text":", ","kind":"text"},{"text":"Error","preciseIdentifier":"s:8BrazeKit0A0C13WebViewBridgeO20ScriptMessageHandlerC5ErrorO","kind":"typeIdentifier","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler\/Error"},{"text":">) -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":")? = nil)","kind":"text"}]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The JavaScript string to use as the function body. This method treats"},{"type":"text","text":" "},{"type":"text","text":"the string as an anonymous JavaScript function body and calls it with"},{"text":" ","type":"text"},{"text":"the named arguments in the ","type":"text"},{"code":"arguments","type":"codeVoice"},{"type":"text","text":" parameter."}]}],"name":"functionBody"},{"name":"arguments","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A dictionary of the arguments to pass to the function call. Each key in the"},{"type":"text","text":" "},{"type":"text","text":"dictionary corresponds to the name of an argument in the functionBody"},{"type":"text","text":" "},{"type":"text","text":"string, and the value of that key is the value to use during the evaluation"},{"type":"text","text":" "},{"type":"text","text":"of the code. Supported value types are "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":", "},{"code":"NSString","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"NSArray"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"NSDictionary"},{"type":"text","text":", or "},{"type":"codeVoice","code":"NSNull"},{"type":"text","text":". All items in an array or dictionary must also"},{"text":" ","type":"text"},{"text":"be one of the supported types.","type":"text"}]}]},{"name":"webView","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The web view in which the JavaScript function is executed. The web view must"},{"text":" ","type":"text"},{"text":"implement the ","type":"text"},{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler","isActive":true},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A handler block to execute when script evaluation finishes. The","type":"text"},{"type":"text","text":" "},{"type":"text","text":"method calls your block whether script evaluation completes"},{"text":" ","type":"text"},{"text":"successfully or fails. The block has no return value and takes the","type":"text"},{"type":"text","text":" "},{"text":"following parameter:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"result: The result of the script evaluation, or an error object that contains"},{"text":" ","type":"text"},{"text":"information about the problem that occurred. If your function body doesn’t","type":"text"},{"text":" ","type":"text"},{"text":"return an explicit value, WebKit passes ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to your completion handler on"},{"type":"text","text":" "},{"type":"text","text":"success. If your function explicitly returns null, WebKit returns that value"},{"text":" ","type":"text"},{"type":"text","text":"as an "},{"code":"NSNull","type":"codeVoice"},{"type":"text","text":" object."}]}]}]}],"name":"completionHandler"}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"aside","content":[{"inlineContent":[{"type":"text","text":"This function is a backport of the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"WKWebView.callAsyncJavaScript(_:arguments:in:completionHandler:)"},{"type":"text","text":" method. It relies on"},{"text":" ","type":"text"},{"text":"the script message handler to pass the result or error to the native side","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"asynchronously."}],"type":"paragraph"},{"inlineContent":[{"text":"It differs from the WebKit method in the following ways:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No support for passing "},{"code":"NSDate","type":"codeVoice"},{"text":" as an argument.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Errors are not wrapped in a ","type":"text"},{"code":"WKError","type":"codeVoice"},{"text":" object.","type":"text"}],"type":"paragraph"}]}]}],"style":"note","name":"Note"},{"inlineContent":[{"type":"text","text":"Don’t format the string in the "},{"type":"codeVoice","code":"functionBody"},{"text":" parameter as a function-like callable","type":"text"},{"type":"text","text":" "},{"text":"object, as you would in pure JavaScript. Instead, put only the body of the function in the","type":"text"},{"type":"text","text":" "},{"text":"string. For example, the following string shows a valid function body that takes x, y, and","type":"text"},{"type":"text","text":" "},{"text":"z arguments and returns a result.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"js","code":["return x ? y : z"]},{"inlineContent":[{"text":"If your JavaScript code returns an object with a callable ","type":"text"},{"type":"codeVoice","code":"then"},{"type":"text","text":" property, the function"},{"type":"text","text":" "},{"type":"text","text":"calls that property on the resulting object and waits for its resolution. If resolution"},{"text":" ","type":"text"},{"type":"text","text":"succeeds, the function passes the resulting object to your completion handler. If"},{"type":"text","text":" "},{"type":"text","text":"resolution fails, the function returns an error to your completion handler."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because this method calls your JavaScript code asynchronously, you can call "},{"type":"codeVoice","code":"await"},{"text":" on","type":"text"},{"type":"text","text":" "},{"text":"objects with a then property inside your function body. The following code example","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"illustrates this technique."}]},{"syntax":"js","code":["var p = new Promise(function (f) {","  window.setTimeout(\"f(42)\", 1000);","});","await p;","return p;"],"type":"codeListing"}]}],"hierarchy":{"paths":[["doc:\/\/Braze\/documentation\/BrazeKit","doc:\/\/Braze\/documentation\/BrazeKit\/Braze","doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/