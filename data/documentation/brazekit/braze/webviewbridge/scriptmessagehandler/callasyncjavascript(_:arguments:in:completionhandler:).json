{"interfaceLanguage":"swift"}],"paths":["\/documentation\/brazekit\/braze\/webviewbridge\/scriptmessagehandler\/callasyncjavascript(_:arguments:in:completionhandler:)"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/Braze\/documentation\/BrazeKit","doc:\/\/Braze\/documentation\/BrazeKit\/Braze","doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge","doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["iOS"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"callAsyncJavaScript","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"text":"functionBody","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"arguments","kind":"externalParam"},{"text":": [","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"kind":"keyword","text":"Any"},{"kind":"text","text":"] = [:], "},{"text":"in","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"webView","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"WKWebView","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)WKWebView"},{"kind":"text","text":", "},{"kind":"externalParam","text":"completionHandler"},{"text":": (@","kind":"text"},{"text":"MainActor","kind":"typeIdentifier","preciseIdentifier":"s:ScM"},{"text":" (","kind":"text"},{"text":"Result","preciseIdentifier":"s:s6ResultO","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Any","kind":"keyword"},{"kind":"text","text":", "},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler\/Error","preciseIdentifier":"s:8BrazeKit0A0C13WebViewBridgeO20ScriptMessageHandlerC5ErrorO","kind":"typeIdentifier","text":"Error"},{"kind":"text","text":">) -> "},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":")? = nil)","kind":"text"}]}]},{"parameters":[{"content":[{"inlineContent":[{"text":"The JavaScript string to use as the function body. This method treats","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the string as an anonymous JavaScript function body and calls it with"},{"type":"text","text":" "},{"text":"the named arguments in the ","type":"text"},{"type":"codeVoice","code":"arguments"},{"type":"text","text":" parameter."}],"type":"paragraph"}],"name":"functionBody"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A dictionary of the arguments to pass to the function call. Each key in the"},{"type":"text","text":" "},{"text":"dictionary corresponds to the name of an argument in the functionBody","type":"text"},{"text":" ","type":"text"},{"text":"string, and the value of that key is the value to use during the evaluation","type":"text"},{"text":" ","type":"text"},{"text":"of the code. Supported value types are ","type":"text"},{"type":"codeVoice","code":"NSNumber"},{"text":", ","type":"text"},{"type":"codeVoice","code":"NSString"},{"type":"text","text":", "},{"type":"codeVoice","code":"NSArray"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"codeVoice","code":"NSDictionary"},{"type":"text","text":", or "},{"type":"codeVoice","code":"NSNull"},{"text":". All items in an array or dictionary must also","type":"text"},{"type":"text","text":" "},{"type":"text","text":"be one of the supported types."}]}],"name":"arguments"},{"name":"webView","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The web view in which the JavaScript function is executed. The web view must"},{"text":" ","type":"text"},{"type":"text","text":"implement the "},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler","isActive":true,"type":"reference"},{"text":".","type":"text"}]}]},{"name":"completionHandler","content":[{"type":"paragraph","inlineContent":[{"text":"A handler block to execute when script evaluation finishes. The","type":"text"},{"type":"text","text":" "},{"type":"text","text":"method calls your block whether script evaluation completes"},{"text":" ","type":"text"},{"type":"text","text":"successfully or fails. The block has no return value and takes the"},{"text":" ","type":"text"},{"text":"following parameter:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"result: The result of the script evaluation, or an error object that contains"},{"text":" ","type":"text"},{"type":"text","text":"information about the problem that occurred. If your function body doesn’t"},{"text":" ","type":"text"},{"type":"text","text":"return an explicit value, WebKit passes "},{"type":"codeVoice","code":"nil"},{"text":" to your completion handler on","type":"text"},{"type":"text","text":" "},{"text":"success. If your function explicitly returns null, WebKit returns that value","type":"text"},{"text":" ","type":"text"},{"text":"as an ","type":"text"},{"code":"NSNull","type":"codeVoice"},{"type":"text","text":" object."}]}]}],"type":"unorderedList"}]}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"name":"Note","style":"note","content":[{"inlineContent":[{"text":"This function is a backport of the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"WKWebView.callAsyncJavaScript(_:arguments:in:completionHandler:)"},{"type":"text","text":" method. It relies on"},{"type":"text","text":" "},{"text":"the script message handler to pass the result or error to the native side","type":"text"},{"type":"text","text":" "},{"text":"asynchronously.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"It differs from the WebKit method in the following ways:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"No support for passing "},{"type":"codeVoice","code":"NSDate"},{"type":"text","text":" as an argument."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Errors are not wrapped in a "},{"code":"WKError","type":"codeVoice"},{"text":" object.","type":"text"}]}]}],"type":"unorderedList"}],"type":"aside"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Don’t format the string in the "},{"type":"codeVoice","code":"functionBody"},{"text":" parameter as a function-like callable","type":"text"},{"type":"text","text":" "},{"text":"object, as you would in pure JavaScript. Instead, put only the body of the function in the","type":"text"},{"type":"text","text":" "},{"text":"string. For example, the following string shows a valid function body that takes x, y, and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"z arguments and returns a result."}]},{"syntax":"js","type":"codeListing","code":["return x ? y : z"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your JavaScript code returns an object with a callable "},{"code":"then","type":"codeVoice"},{"type":"text","text":" property, the function"},{"type":"text","text":" "},{"type":"text","text":"calls that property on the resulting object and waits for its resolution. If resolution"},{"text":" ","type":"text"},{"type":"text","text":"succeeds, the function passes the resulting object to your completion handler. If"},{"type":"text","text":" "},{"type":"text","text":"resolution fails, the function returns an error to your completion handler."}]},{"type":"paragraph","inlineContent":[{"text":"Because this method calls your JavaScript code asynchronously, you can call ","type":"text"},{"type":"codeVoice","code":"await"},{"type":"text","text":" on"},{"type":"text","text":" "},{"text":"objects with a then property inside your function body. The following code example","type":"text"},{"type":"text","text":" "},{"type":"text","text":"illustrates this technique."}]},{"syntax":"js","code":["var p = new Promise(function (f) {","  window.setTimeout(\"f(42)\", 1000);","});","await p;","return p;"],"type":"codeListing"}]}],"references":{"doc://Braze/documentation/BrazeKit/Braze":{"url":"\/documentation\/brazekit\/braze","kind":"symbol","role":"symbol","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze","title":"Braze","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Braze","kind":"identifier"}],"abstract":[{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze","isActive":true},{"type":"text","text":" is the main entry point of the BrazeKit module and provides access to all its features."}],"navigatorTitle":[{"text":"Braze","kind":"identifier"}]},"doc://Braze/documentation/BrazeKit/Braze/WebViewBridge/ScriptMessageHandler/Error":{"title":"Braze.WebViewBridge.ScriptMessageHandler.Error","role":"symbol","url":"\/documentation\/brazekit\/braze\/webviewbridge\/scriptmessagehandler\/error","navigatorTitle":[{"text":"Error","kind":"identifier"}],"type":"topic","abstract":[],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Error","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMessageHandler\/Error"},"doc://Braze/documentation/BrazeKit/Braze/WebViewBridge/ScriptMessageHandler/callAsyncJavaScript(_:arguments:in:completionHandler:)":{"abstract":[{"type":"text","text":"Executes the specified string as an asynchronous JavaScript function."}],"url":"\/documentation\/brazekit\/braze\/webviewbridge\/scriptmessagehandler\/callasyncjavascript(_:arguments:in:completionhandler:)","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/WebViewBridge\/ScriptMes