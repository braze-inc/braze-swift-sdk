{"sections":[],"metadata":{"roleHeading":"Instance Property","externalID":"s:8BrazeKit0A0C13ConfigurationC4PushC10automationAG10AutomationCvp","modules":[{"name":"BrazeKit"}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"automation","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:8BrazeKit0A0C13ConfigurationC4PushC10AutomationC","text":"Automation","kind":"typeIdentifier"}],"symbolKind":"property","role":"symbol","title":"automation"},"hierarchy":{"paths":[["doc:\/\/Braze\/documentation\/BrazeKit","doc:\/\/Braze\/documentation\/BrazeKit\/Braze","doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class","doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/Push-swift.class"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"@objc","kind":"attribute"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"automation","kind":"identifier"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/Push-swift.class\/Automation-swift.class","preciseIdentifier":"s:8BrazeKit0A0C13ConfigurationC4PushC10AutomationC","text":"Automation","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"name":"Important","style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK must be initialized on the main thread to enable push notification"},{"type":"text","text":" "},{"type":"text","text":"automation. SDK initialization must happen before the application has finished launching"},{"type":"text","text":" "},{"type":"text","text":"or in your AppDelegate "},{"type":"reference","identifier":"https:\/\/archive.is\/nUG1k","isActive":true},{"type":"text","text":" implementation."},{"type":"text","text":" "},{"type":"text","text":"If the application setup requires the SDK to be initialized after the application has"},{"type":"text","text":" "},{"type":"text","text":"finished launching, refer to the"},{"text":" ","type":"text"},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/prepareForDelayedInitialization(pushAutomation:analyticsBehavior:)","type":"reference","isActive":true},{"text":" method.","type":"text"}]}],"type":"aside"},{"name":"Note","style":"note","content":[{"inlineContent":[{"text":"The automation steps performed by the SDK are compatible with pre-existing push","type":"text"},{"text":" ","type":"text"},{"text":"notification handling integrations in your codebase. The SDK only automates the","type":"text"},{"text":" ","type":"text"},{"text":"processing of remote notification received from Braze. Any system handler implemented","type":"text"},{"text":" ","type":"text"},{"text":"to process your own or another third party SDK remote notifications will continue to","type":"text"},{"text":" ","type":"text"},{"text":"work when ","type":"text"},{"code":"automation","type":"codeVoice"},{"text":" is enabled.","type":"text"}],"type":"paragraph"}],"type":"aside"},{"inlineContent":[{"text":"By default, the SDK does not perform any automation steps and you are required to implement","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"UIApplicationDelegate"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":" methods yourself as","type":"text"},{"text":" ","type":"text"},{"text":"described in the ","type":"text"},{"identifier":"doc:\/\/Braze\/tutorials\/Braze\/b1-standard-push-notifications","type":"reference","isActive":true},{"text":" tutorial.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can enable automatic push notification handling as follows:"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["configuration.push.automation = true"]},{"inlineContent":[{"text":"This instructs the SDK to:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Register your application for push notification on the system."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Request the push notification authorization \/ permission at initialization.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Dynamically provide implementations for the push notification related system delegate","type":"text"},{"text":" ","type":"text"},{"text":"methods.","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"For a more granular behavior, each automation step can be enabled individually:"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["\/\/ Automate only the `application(_:didRegisterForRemoteNotificationsWithDeviceToken:)`","\/\/ delegate method","configuration.push.automation.registerDeviceToken = true"]},{"inlineContent":[{"type":"text","text":"Or you can perform a combination of both approaches:"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["\/\/ Enable all automations","configuration.push.automation = true","\/\/ Disable the automatic notification authorization request at launch.","configuration.push.automation.requestAuthorizationAtLaunch = false"]},{"type":"aside","style":"important","name":"Important","content":[{"inlineContent":[{"type":"text","text":"When enabled, the "},{"type":"codeVoice","code":"UIApplicationDelegate"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"type":"text","text":" methods will not be executed when processing remote"},{"type":"text","text":" "},{"type":"text","text":"notifications received from Braze."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Notifications-swift.class\/subscribeToUpdates(payloadTypes:_:)","type":"reference","isActive":true},{"type":"text","text":" to subscribe to"},{"type":"text","text":" "},{"type":"text","text":"those push notification updates when "},{"code":"automation","type":"codeVoice"},{"type":"text","text":" is enabled."}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The behavior of each automation step is described in"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/Push-swift.class\/Automation-swift.class"},{"type":"text","text":"."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/brazekit\/braze\/configuration-swift.class\/push-swift.class\/automation-swift.property"]}],"abstract":[{"type":"text","text":"The automatic push notification handling behavior (default: disabled)."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/Push-swift.class\/automation-swift.property"},"kind":"symbol","references":{"doc://Braze/documentation/BrazeKit/Braze/Configuration-swift.class/Push-swift.class":{"kind":"symbol","type":"topic","abstract":[{"text":"Push configuration.","type":"text"}],"title":"Braze.Configuration.Push","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/Push-swift.class","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Push","kind":"identifier"}],"navigatorTitle":[{"text":"Push","kind":"identifier"}],"url":"\/documentation\/brazekit\/braze\/configuration-swift.class\/push-swift.class"},"doc://Braze/documentation/BrazeKit/Braze/prepareForDelayed