{"abstract":[{"type":"text","text":"The automatic push notification handling behavior (default: disabled)."}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@objc","kind":"attribute"},{"kind":"text","text":" "},{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"automation"},{"kind":"text","text":": "},{"text":"Automation","kind":"typeIdentifier","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/Push-swift.class\/Automation-swift.class","preciseIdentifier":"s:8BrazeKit0A0C13ConfigurationC4PushC10AutomationC"},{"kind":"text","text":" { "},{"text":"get","kind":"keyword"},{"kind":"text","text":" "},{"text":"set","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"style":"important","type":"aside","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"The SDK must be initialized on the main thread to enable push notification","type":"text"},{"type":"text","text":" "},{"text":"automation. SDK initialization must happen before the application has finished launching","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or in your AppDelegate "},{"isActive":true,"identifier":"https:\/\/archive.is\/nUG1k","type":"reference"},{"type":"text","text":" implementation."},{"text":" ","type":"text"},{"type":"text","text":"If the application setup requires the SDK to be initialized after the application has"},{"type":"text","text":" "},{"type":"text","text":"finished launching, refer to the"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/prepareForDelayedInitialization(pushAutomation:analyticsBehavior:)"},{"type":"text","text":" method."}]}]},{"style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"The automation steps performed by the SDK are compatible with pre-existing push"},{"type":"text","text":" "},{"text":"notification handling integrations in your codebase. The SDK only automates the","type":"text"},{"text":" ","type":"text"},{"text":"processing of remote notification received from Braze. Any system handler implemented","type":"text"},{"type":"text","text":" "},{"text":"to process your own or another third party SDK remote notifications will continue to","type":"text"},{"text":" ","type":"text"},{"text":"work when ","type":"text"},{"code":"automation","type":"codeVoice"},{"type":"text","text":" is enabled."}],"type":"paragraph"}],"name":"Note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, the SDK does not perform any automation steps and you are required to implement"},{"type":"text","text":" "},{"type":"text","text":"the "},{"code":"UIApplicationDelegate","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"type":"text","text":" methods yourself as"},{"type":"text","text":" "},{"type":"text","text":"described in the "},{"identifier":"doc:\/\/Braze\/tutorials\/Braze\/b1-standard-push-notifications","type":"reference","isActive":true},{"text":" tutorial.","type":"text"}]},{"inlineContent":[{"text":"You can enable automatic push notification handling as follows:","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["configuration.push.automation = true"]},{"type":"paragraph","inlineContent":[{"text":"This instructs the SDK to:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Register your application for push notification on the system."}]}]},{"content":[{"inlineContent":[{"text":"Request the push notification authorization \/ permission at initialization.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Dynamically provide implementations for the push notification related system delegate"},{"text":" ","type":"text"},{"type":"text","text":"methods."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"For a more granular behavior, each automation step can be enabled individually:","type":"text"}]},{"syntax":null,"code":["\/\/ Automate only the `application(_:didRegisterForRemoteNotificationsWithDeviceToken:)`","\/\/ delegate method","configuration.push.automation.registerDeviceToken = true"],"type":"codeListing"},{"inlineContent":[{"text":"Or you can perform a combination of both approaches:","type":"text"}],"type":"paragraph"},{"code":["\/\/ Enable all automations","configuration.push.automation = true","\/\/ Disable the automatic notification authorization request at launch.","configuration.push.automation.requestAuthorizationAtLaunch = false"],"syntax":null,"type":"codeListing"},{"name":"Important","type":"aside","content":[{"inlineContent":[{"text":"When enabled, the ","type":"text"},{"code":"UIApplicationDelegate","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"type":"text","text":" methods will not be executed when processing remote"},{"type":"text","text":" "},{"text":"notifications received from Braze.","type":"text"},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Notifications-swift.class\/subscribeToUpdates(payloadTypes:_:)","isActive":true,"type":"reference"},{"text":" to subscribe to","type":"text"},{"type":"text","text":" "},{"text":"those push notification updates when ","type":"text"},{"code":"automation","type":"codeVoice"},{"type":"text","text":" is enabled."}],"type":"paragraph"}],"style":"important"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The behavior of each automation step is described in"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Braze\