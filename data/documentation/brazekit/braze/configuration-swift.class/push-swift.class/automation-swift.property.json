{"identifier":{"url":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/Push-swift.class\/automation-swift.property","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"automation","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Automation","kind":"typeIdentifier","preciseIdentifier":"s:8BrazeKit0A0C13ConfigurationC4PushC10AutomationC"}],"modules":[{"name":"BrazeKit"}],"roleHeading":"Instance Property","title":"automation","symbolKind":"property","externalID":"s:8BrazeKit0A0C13ConfigurationC4PushC10automationAG10AutomationCvp","role":"symbol"},"abstract":[{"type":"text","text":"The automatic push notification handling behavior (default: disabled)."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@objc"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"automation"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Automation","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/Push-swift.class\/Automation-swift.class","preciseIdentifier":"s:8BrazeKit0A0C13ConfigurationC4PushC10AutomationC"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" "},{"kind":"keyword","text":"set"},{"kind":"text","text":" }"}],"languages":["swift"],"platforms":["iOS"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK must be initialized on the main thread to enable push notification"},{"type":"text","text":" "},{"type":"text","text":"automation. SDK initialization must happen before the application has finished launching"},{"type":"text","text":" "},{"type":"text","text":"or in your AppDelegate "},{"type":"reference","identifier":"https:\/\/archive.is\/nUG1k","isActive":true},{"type":"text","text":" implementation."},{"type":"text","text":" "},{"type":"text","text":"If the application setup requires the SDK to be initialized after the application has"},{"type":"text","text":" "},{"type":"text","text":"finished launching, refer to the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/prepareForDelayedInitialization(pushAutomation:analyticsBehavior:)","isActive":true},{"type":"text","text":" method."}]}],"style":"important","name":"Important"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"The automation steps performed by the SDK are compatible with pre-existing push","type":"text"},{"text":" ","type":"text"},{"text":"notification handling integrations in your codebase. The SDK only automates the","type":"text"},{"text":" ","type":"text"},{"text":"processing of remote notification received from Braze. Any system handler implemented","type":"text"},{"text":" ","type":"text"},{"text":"to process your own or another third party SDK remote notifications will continue to","type":"text"},{"text":" ","type":"text"},{"text":"work when ","type":"text"},{"code":"automation","type":"codeVoice"},{"text":" is enabled.","type":"text"}]}],"style":"note","name":"Note"},{"type":"paragraph","inlineContent":[{"text":"By default, the SDK does not perform any automation steps and you are required to implement","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"UIApplicationDelegate","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"text":" methods yourself as","type":"text"},{"text":" ","type":"text"},{"text":"described in the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Braze\/tutorials\/Braze\/b1-standard-push-notifications"},{"text":" tutorial.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can enable automatic push notification handling as follows:"}]},{"type":"codeListing","syntax":null,"code":["configuration.push.automation = true"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This instructs the SDK to:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Register your application for push notification on the system.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Request the push notification authorization \/ permission at initialization."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Dynamically provide implementations for the push notification related system delegate","type":"text"},{"text":" ","type":"text"},{"text":"methods.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"For a more granular behavior, each automation step can be enabled individually:","type":"text"}]},{"syntax":null,"type":"codeListing","code":["\/\/ Automate only the `application(_:didRegisterForRemoteNotificationsWithDeviceToken:)`","\/\/ delegate method","configuration.push.automation.registerDeviceToken = true"]},{"type":"paragraph","inlineContent":[{"text":"Or you can perform a combination of both approaches:","type":"text"}]},{"syntax":null,"type":"codeListing","code":["\/\/ Enable all automations","configuration.push.automation = true","\/\/ Disable the automatic notification authorization request at launch.","configuration.push.automation.requestAuthorizationAtLaunch = false"]},{"style":"important","name":"Important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"When enabled, the ","type":"text"},{"code":"UIApplicationDelegate","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"text":" methods will not be executed when processing remote","type":"text"},{"text":" ","type":"text"},{"text":"notifications received from Braze.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Notifications-swift.class\/subscribeToUpdates(payloadTypes:_:)","isActive":true,"type":"reference"},{"text":" to subscribe to","type":"text"},{"text":" ","type":"text"},{"text":"those push notification updates when ","type":"text"},{"code":"automation","type":"codeVoice"},{"text":" is enabled.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The behavior of each automation step is described in"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/Push-swift.class\/Automation-swift.class"},{"type":"text","text":"."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/brazekit\/braze\/configuration-swift.class\/push-swift.class\/automation-swift.property"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/Braze\/documentation\/BrazeKit","doc:\/\/Braze\/documentation\/BrazeKit\/Braze","doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class","doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/Push-swift.class"]]},"references":{"doc://Braze/documentation/BrazeKit":{"abstract":[{"type":"text","text":"The main Braze framework providing user sessions, attributes and events logging, push notification support."}],"kind":"symbol","identifier":"doc:\/\/Braze\/documentation\/BrazeKit","url":"\/documentation\/brazekit","role":"collection","title":"BrazeKit","type":"topic"},"doc://Braze/documentation/BrazeKit/Braze/Configuration-swift.class":{"type":"topic","url":"\/documentation\/brazekit\/braze\/configuration-swift.class","title":"Braze.Configuration","abstract":[{"type":"text","text":"The Braze SDK configuration."}],"identifier":"doc:\/\/Braze\/documentation\/BrazeKit