{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"attribute","text":"@objc"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"automation"},{"kind":"text","text":": "},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/Push-swift.class\/Automation-swift.class","preciseIdentifier":"s:8BrazeKit0A0C13ConfigurationC4PushC10AutomationC","kind":"typeIdentifier","text":"Automation"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" "},{"kind":"keyword","text":"set"},{"text":" }","kind":"text"}],"languages":["swift"]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"style":"important","name":"Important","type":"aside","content":[{"inlineContent":[{"type":"text","text":"The SDK must be initialized on the main thread to enable push notification"},{"type":"text","text":" "},{"type":"text","text":"automation. SDK initialization must happen before the application has finished launching"},{"type":"text","text":" "},{"type":"text","text":"or in your AppDelegate "},{"type":"reference","isActive":true,"identifier":"https:\/\/archive.is\/nUG1k"},{"type":"text","text":" implementation."},{"type":"text","text":" "},{"type":"text","text":"If the application setup requires the SDK to be initialized after the application has"},{"type":"text","text":" "},{"type":"text","text":"finished launching, refer to the"},{"text":" ","type":"text"},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/prepareForDelayedInitialization(pushAutomation:analyticsBehavior:)","isActive":true,"type":"reference"},{"text":" method.","type":"text"}],"type":"paragraph"}]},{"style":"note","name":"Note","type":"aside","content":[{"inlineContent":[{"text":"The automation steps performed by the SDK are compatible with pre-existing push","type":"text"},{"text":" ","type":"text"},{"text":"notification handling integrations in your codebase. The SDK only automates the","type":"text"},{"text":" ","type":"text"},{"text":"processing of remote notification received from Braze. Any system handler implemented","type":"text"},{"text":" ","type":"text"},{"text":"to process your own or another third party SDK remote notifications will continue to","type":"text"},{"text":" ","type":"text"},{"text":"work when ","type":"text"},{"type":"codeVoice","code":"automation"},{"text":" is enabled.","type":"text"}],"type":"paragraph"}]},{"inlineContent":[{"text":"By default, the SDK does not perform any automation steps and you are required to implement","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"UIApplicationDelegate","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"text":" methods yourself as","type":"text"},{"text":" ","type":"text"},{"text":"described in the ","type":"text"},{"identifier":"doc:\/\/Braze\/tutorials\/Braze\/b1-standard-push-notifications","isActive":true,"type":"reference"},{"text":" tutorial.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can enable automatic push notification handling as follows:"}],"type":"paragraph"},{"code":["configuration.push.automation = true"],"type":"codeListing","syntax":null},{"inlineContent":[{"text":"This instructs the SDK to:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Register your application for push notification on the system.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Request the push notification authorization \/ permission at initialization.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Dynamically provide implementations for the push notification related system delegate","type":"text"},{"text":" ","type":"text"},{"text":"methods.","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"For a more granular behavior, each automation step can be enabled individually:","type":"text"}],"type":"paragraph"},{"code":["\/\/ Automate only the `application(_:didRegisterForRemoteNotificationsWithDeviceToken:)`","\/\/ delegate method","configuration.push.automation.registerDeviceToken = true"],"type":"codeListing","syntax":null},{"inlineContent":[{"text":"Or you can perform a combination of both approaches:","type":"text"}],"type":"paragraph"},{"code":["\/\/ Enable all automations","configuration.push.automation = true","\/\/ Disable the automatic notification authorization request at launch.","configuration.push.automation.requestAuthorizationAtLaunch = false"],"type":"codeListing","syntax":null},{"style":"important","name":"Important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When enabled, the "},{"type":"codeVoice","code":"UIApplicationDelegate"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"type":"text","text":" methods will not be executed when processing remote"},{"type":"text","text":" "},{"type":"text","text":"notifications received from Braze."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Notifications-swift.class\/subscribeToUpdates(payloadTypes:_:)","type":"reference","isActive":true},{"type":"text","text":" to subscribe to"},{"type":"text","text":" "},{"type":"text","text":"those push notification updates when "},{"code":"automation","type":"codeVoice"},{"type":"text","text":" is enabled."}]}]},{"inlineContent":[{"text":"The behavior of each automation step is described in","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/Push-swift.class\/Automation-swift.class","isActive":true},{"text":".","type":"tex