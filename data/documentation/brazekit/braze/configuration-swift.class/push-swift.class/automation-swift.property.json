"text"},{"text":" ","type":"text"},{"text":"methods.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"For a more granular behavior, each automation step can be enabled individually:","type":"text"}]},{"type":"codeListing","syntax":null,"code":["\/\/ Automate only the `application(_:didRegisterForRemoteNotificationsWithDeviceToken:)`","\/\/ delegate method","configuration.push.automation.registerDeviceToken = true"]},{"type":"paragraph","inlineContent":[{"text":"Or you can perform a combination of both approaches:","type":"text"}]},{"code":["\/\/ Enable all automations","configuration.push.automation = true","\/\/ Disable the automatic notification authorization request at launch.","configuration.push.automation.requestAuthorizationAtLaunch = false"],"syntax":null,"type":"codeListing"},{"name":"Important","style":"important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"When enabled, the ","type":"text"},{"type":"codeVoice","code":"UIApplicationDelegate"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":" methods will not be executed when processing remote","type":"text"},{"text":" ","type":"text"},{"text":"notifications received from Braze.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Notifications-swift.class\/subscribeToUpdates(payloadTypes:_:)"},{"text":" to subscribe to","type":"text"},{"text":" ","type":"text"},{"text":"those push notification updates when ","type":"text"},{"type":"codeVoice","code":"automation"},{"text":" is enabled.","type":"text"}]}]},{"inlineContent":[{"type":"text","text":"The behavior of each automation step is described in"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Braze\/documentation\/BrazeKit\/Braze\/Configuration-swift.class\/P